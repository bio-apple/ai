{
  "name": "ai-guide",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <26"
  },
  "scripts": {
    "prebuild": "node scripts/prebuild.mjs",
    "build": "astro build",
    "dev": "node scripts/prebuild.mjs && astro dev",
    "preview": "astro preview --host 127.0.0.1 --port 8766",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "quality": "npm run format:check && npm run lint",
    "scan:secrets": "python3 scripts/validate_ci.py secrets",
    "test:unit": "node --test tests/unit/*.test.mjs && python3 -m unittest discover -s tests/unit -p 'test_*.py'",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "health:live": "python3 scripts/check_site_health.py",
    "optimize:images": "node scripts/optimize-images.mjs"
  },
  "dependencies": {
    "astro": "^5.7.10"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.3.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.55.1",
    "eslint": "^10.7.0",
    "globals": "^16.5.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.34.5"
  }
}

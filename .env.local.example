# 本地开发环境变量（复制为 .env.local，勿提交 Git）
# cp .env.local.example .env.local
# 安全规范：https://github.com/bio-apple/ai/blob/main/docs/SECURITY.md

# ── 构建 / 分析（可选，CI 使用 GitHub Actions Secrets）──
# GA_MEASUREMENT_ID=
# CLARITY_PROJECT_ID=
# UMAMI_SCRIPT_URL=
# UMAMI_WEBSITE_ID=
# CLOUDFLARE_BEACON_TOKEN=

# ── 数据抓取（可选，提高 GitHub API 限额）──
# GITHUB_TOKEN=

# YouTube Data API v3：CI/本地抓取视频详情（规避 yt-dlp「Sign in to confirm you're not a bot」）
# 在 Google Cloud Console 启用 YouTube Data API v3 后创建 API Key，写入 GitHub Actions Secret：YOUTUBE_API_KEY
# YOUTUBE_API_KEY=

# 可选：yt-dlp Netscape cookies 本地文件路径（无 API Key 时备用，需定期更新）
# YTDLP_COOKIES_FILE=/path/to/youtube_cookies.txt
# CI 可选 Secret：YTDLP_COOKIES_B64（cookies 文件 base64 编码）

# ── LLM 服务商 API Key（禁止写入仓库）──
# 若未来在浏览器内接入用户自填 Key，仅保存在 localStorage/sessionStorage，
# 且请求必须直连官方 API，禁止经第三方中转。
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=

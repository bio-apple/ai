---
import { pickHomeVideos, formatNumber, formatPublishDate } from '../lib/runtime';

const HOT = 1_000_000;
const videos = pickHomeVideos(3);

function platformLabel(v: (typeof videos)[number]) {
  if (v.platform === 'bilibili' || String(v.id || '').startsWith('bilibili:')) return 'B站';
  return 'YouTube';
}

function isBilibili(v: (typeof videos)[number]) {
  return v.platform === 'bilibili' || String(v.id || '').startsWith('bilibili:');
}
---
<div id="home-video-preview" class="home-video-preview" data-ssg="1">
  {videos.length === 0 ? (
    <p class="loading-hint">暂无视频，每日北京时间 0:00 自动更新。</p>
  ) : (
    <div class="video-grid video-grid-preview">
      {videos.map((v) => {
        const hot = (v.views || 0) >= HOT;
        const platform = platformLabel(v);
        const author = v.author || v.channel || '未知作者';
        const published = formatPublishDate(v.published_at);
        const summary = hot ? `热门推荐 · ${v.summary || ''}` : (v.summary || '');
        return (
          <article class="video-card reveal video-card-compact">
            <a class="video-thumb" href={v.url} target="_blank" rel="noopener" data-track="home-video-click">
              <img
                src={v.thumbnail || ''}
                alt={v.title}
                loading="lazy"
                referrerpolicy={isBilibili(v) ? 'no-referrer' : undefined}
              />
              <span class="video-play-btn" aria-hidden="true">▶ 观看</span>
              {v.duration && <span class="video-duration">{v.duration}</span>}
              {v.max_height != null && <span class="video-quality">{v.max_height}p</span>}
              <span class={`video-platform video-platform-${v.platform || 'youtube'}`}>{platform}</span>
              {hot && <span class="video-hot">热门</span>}
            </a>
            <div class="video-body">
              <h4>
                <a href={v.url} target="_blank" rel="noopener" data-track="home-video-click">{v.title}</a>
              </h4>
              <p class="video-summary">{summary}</p>
              <div class="video-meta">
                <span>{author}</span>
                {published && <span>{published}</span>}
                <span>播放 {formatNumber(v.views || 0)}</span>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  )}
</div>

---
interface Props {
  text: string;
  github: string;
}
const { text, github } = Astro.props;
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <p class="site-footer-copy">{text}</p>
    <a
      class="github-star-btn github-star-btn-footer"
      href={github}
      target="_blank"
      rel="noopener"
      data-track="github-star-footer"
    >
      <span aria-hidden="true">★</span> Star on GitHub
    </a>
  </div>
</footer>

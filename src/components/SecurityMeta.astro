---
import { buildCspPolicy } from '../../scripts/csp-policy.mjs';

/**
 * GitHub Pages 无法自定义 HTTP 响应头时的兜底。
 * 完整 CSP / HSTS 以 `config/csp.json` → `_headers` 为准（Cloudflare 边缘注入）。
 * meta CSP 省略 frame-ancestors；ThemeBoot 内联脚本仍需 script-src unsafe-inline。
 */
const csp = buildCspPolicy({ forMeta: true });
---

<meta http-equiv="Content-Security-Policy" content={csp} />
<meta name="referrer" content="strict-origin-when-cross-origin" />

---
import type { site as SiteType } from '../../data/site.json';

interface Props {
  nav: typeof SiteType.nav;
  standalone?: boolean;
  homeHref?: string;
  navPrefix?: string;
}

const { nav, standalone = false, homeHref = 'index.html', navPrefix = '' } = Astro.props;
---

<header>
  <nav class="nav">
    <a href={homeHref} class="logo" data-tool="all" aria-label="返回首页">
      <div class="logo-icon" aria-hidden="true">{nav.logo.icon}</div>
      <div class="logo-text">
        <span class="logo-brand">{nav.logo.brand}</span>
        <span class="logo-tagline">{nav.logo.tagline}</span>
      </div>
    </a>
    <button class="nav-toggle" type="button" aria-label="打开导航" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-menu">
      {
        nav.menu.map((item) => {
          if (item.type === 'dropdown') {
            return (
              <div class="nav-dropdown">
                <button type="button" class="nav-dropdown-trigger" aria-haspopup="true">
                  {item.label} <span class="nav-chevron">▾</span>
                </button>
                <div class="nav-dropdown-menu" role="menu">
                  {item.children?.map((sub) => {
                    const href = 'href' in sub && sub.href ? String(sub.href) : '';
                    if (href) {
                      return (
                        <a href={`${navPrefix}${href}`} class="nav-dropdown-item" role="menuitem">
                          {sub.label}
                        </a>
                      );
                    }
                    if (!('id' in sub) || !sub.id) return null;
                    return standalone ? (
                      <a
                        href={`${homeHref}#section-${sub.id}`}
                        class="nav-dropdown-item"
                        role="menuitem"
                      >
                        {sub.label}
                      </a>
                    ) : (
                      <button
                        type="button"
                        class="nav-dropdown-item"
                        data-tool={sub.id}
                        role="menuitem"
                      >
                        {sub.label}
                      </button>
                    );
                  })}
                </div>
              </div>
            );
          }
          if (item.type === 'page') {
            return (
              <a href={`${navPrefix}${item.href}`} class="nav-link-page">
                {item.label}
              </a>
            );
          }
          const active = item.id === 'all';
          if (standalone) {
            const href = item.id === 'all' ? homeHref : `${homeHref}#section-${item.id}`;
            return (
              <a href={href} class:list={['nav-tab', { active }]}>
                {item.label}
              </a>
            );
          }
          return (
            <button type="button" class:list={['nav-tab', { active }]} data-tool={item.id}>
              {item.label}
            </button>
          );
        })
      }
      <button type="button" class="theme-toggle" aria-label="切换主题">☾</button>
    </div>
  </nav>
</header>

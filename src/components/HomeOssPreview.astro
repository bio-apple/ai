---
import OssCard from './OssCard.astro';
import { pickHomeOss } from '../lib/runtime';

const items = pickHomeOss(3);
---

<div id="home-oss-preview" class="home-oss-preview" data-ssg="1">
  {
    items.length === 0 ? (
      <p class="loading-hint">暂无开源项目数据。</p>
    ) : (
      <div class="oss-grid">
        {items.map(({ project, domainLabel }) => (
          <OssCard project={project} domainLabel={domainLabel} />
        ))}
      </div>
    )
  }
</div>

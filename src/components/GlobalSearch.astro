---
import { site } from '../lib/data';

interface Props {
  variant?: 'hero' | 'nav';
  placeholder?: string;
  suggestions?: string[];
  showLabel?: boolean;
}

const {
  variant = 'hero',
  placeholder = site.hero.search_placeholder,
  suggestions = site.hero.search_suggestions || [],
  showLabel = variant === 'hero',
} = Astro.props;

const inputId = variant === 'nav' ? 'nav-site-search' : 'site-search';
const resultsId = variant === 'nav' ? 'nav-site-search-results' : 'site-search-results';
const suggestionsJson = JSON.stringify(suggestions);
---

<div
  class:list={[
    'site-search-wrap',
    { 'hero-search': variant === 'hero', 'nav-search': variant === 'nav' },
  ]}
  data-search-suggestions={suggestionsJson}
>
  {
    showLabel && (
      <label class="hero-search-label" for={inputId}>
        全站搜索
      </label>
    )
  }
  <div class="site-search-field">
    <input
      type="search"
      id={inputId}
      class="site-search site-search-input"
      placeholder={placeholder}
      aria-label="全站搜索"
      autocomplete="off"
      enterkeyhint="search"
      data-search-ready="0"
      data-search-status="loading"
    />
    <button type="button" class="site-search-submit" aria-label="搜索">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
        <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="2"></circle>
        <path
          d="M16.5 16.5L21 21"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"></path>
      </svg>
    </button>
  </div>
  <div id={resultsId} class="site-search-results" hidden></div>
</div>

---
import type { Tool } from '../lib/data';
import { resolveToolRelations } from '../lib/data';
import StandalonePageHeader from './StandalonePageHeader.astro';
import { asset, homeHref } from '../lib/paths';

interface Props {
  tool: Tool;
}
const { tool } = Astro.props;
const home = homeHref();
const relations = resolveToolRelations(tool.id);
const hasRelations = relations.alternatives.length > 0 || relations.complements.length > 0;
---

<main class="standalone-page">
  <StandalonePageHeader
    crumbs={[
      { label: '首页', href: home },
      { label: '工具中心', href: asset('tools/hub.html') },
      { label: `${tool.name} 教程` },
    ]}
    title={`${tool.name} 教程 2026`}
    lead={tool.description}
    icon={tool.icon}
    iconClass={tool.id}
  />

  <section class="page-section">
    <div class="grid-2">
      <div class="card">
        <h3><span class="dot"></span> 快速入门</h3>
        <ol class="steps">{tool.getting_started_steps.map((step) => <li set:html={step} />)}</ol>
      </div>
      <div class="card">
        <h3><span class="dot"></span> 核心功能</h3>
        <ul class="features">
          {
            tool.features.map((f) => (
              <li>
                <strong>{f.title}</strong> — {f.description}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
  {
    tool.shortcuts && (
      <section class="page-section">
        <div class="section-head">
          <h2 class="section-title">{tool.shortcuts.title}</h2>
        </div>
        <div class="table-wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <>
                  <th>快捷键</th>
                  <th>功能</th>
                </>
              </tr>
            </thead>
            <tbody>
              {tool.shortcuts.rows.map((row) => (
                <tr>
                  <td set:html={row.key} />
                  <td>{row.action}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )
  }
  {
    tool.video_resources?.length > 0 && (
      <section class="page-section">
        <div class="section-head">
          <h2 class="section-title">视频教程</h2>
        </div>
        <div class="resource-grid">
          {tool.video_resources.map((r) => (
            <div class="resource-item">
              <a href={r.href} target="_blank" rel="noopener">
                <div class={`resource-type ${r.type_class}`}>{r.type}</div>
                <h4>{r.title}</h4>
                <div class="resource-meta">{r.meta}</div>
              </a>
            </div>
          ))}
        </div>
      </section>
    )
  }
  {
    tool.text_resources?.length > 0 && (
      <section class="page-section">
        <div class="section-head">
          <h2 class="section-title">文字资料</h2>
        </div>
        <div class="resource-grid">
          {tool.text_resources.map((r) => (
            <div class="resource-item">
              <a href={r.href} target="_blank" rel="noopener">
                <div class={`resource-type ${r.type_class}`}>{r.type}</div>
                <h4>{r.title}</h4>
                <div class="resource-meta">{r.meta}</div>
              </a>
            </div>
          ))}
        </div>
      </section>
    )
  }
  {
    hasRelations && (
      <section class="page-section tool-relations" aria-label="相关工具">
        {relations.alternatives.length > 0 && (
          <div class="tool-relations-group">
            <div class="section-head">
              <h2 class="section-title">可切换替代</h2>
            </div>
            <ul class="tool-relations-list">
              {relations.alternatives.map((rel) => (
                <li>
                  <a
                    href={rel.href}
                    class="tool-relation-link"
                    data-track={`tool-rel-alt-${tool.id}-${rel.id}`}
                  >
                    <span class={`tool-relation-icon ${rel.id}`}>{rel.icon}</span>
                    <span class="tool-relation-body">
                      <strong>{rel.name}</strong>
                      <span class="tool-relation-note">{rel.note}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
        {relations.complements.length > 0 && (
          <div class="tool-relations-group">
            <div class="section-head">
              <h2 class="section-title">常一起用</h2>
            </div>
            <ul class="tool-relations-list">
              {relations.complements.map((rel) => (
                <li>
                  <a
                    href={rel.href}
                    class="tool-relation-link"
                    data-track={`tool-rel-comp-${tool.id}-${rel.id}`}
                  >
                    <span class={`tool-relation-icon ${rel.id}`}>{rel.icon}</span>
                    <span class="tool-relation-body">
                      <strong>{rel.name}</strong>
                      <span class="tool-relation-note">{rel.note}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </section>
    )
  }
  <div class="standalone-cta">
    <a href={home} class="cta-btn" data-track={`tool-goto-home-${tool.id}`}>返回首页</a>
    <a href={asset('tools/hub.html')} class="cta-btn cta-btn-outline">浏览工具中心</a>
    <a href={asset('ai-tools-ranking.html')} class="cta-btn cta-btn-outline">查看工具排行</a>
  </div>
</main>

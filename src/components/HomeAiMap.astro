---
/**
 * 首页「AI 领域地图」内容区块（非 Hero 背景）
 * - 信息图有独立语义：figure + alt + figcaption
 * - 首屏以下 lazy 加载，不抢 LCP
 * - 移动端 SVG；桌面 WebP srcset
 */
import { asset } from '../lib/paths';

const svg = asset('hero-ai-map.svg');
const w640 = asset('hero-ai-map-640.webp');
const w960 = asset('hero-ai-map-960.webp');
const w1280 = asset('hero-ai-map-1280.webp');
const roadmapHref = asset('ai-learning-roadmap.html');
---

<section
  class="home-section fade-in home-ai-map"
  id="home-ai-map"
  aria-labelledby="home-ai-map-title"
>
  <div class="section-head">
    <p class="section-kicker">知识版图</p>
    <h2 class="section-title" id="home-ai-map-title">AI 领域如何层层嵌套</h2>
    <p class="section-desc">
      Artificial Intelligence ⊃ Machine Learning ⊃ Deep Learning，并与视觉、语音、机器人、NLP
      交叉；外围是数学、神经科学等基础学科。
    </p>
  </div>

  <figure class="ai-map-figure">
    <picture>
      <source
        media="(min-width: 768px)"
        type="image/webp"
        srcset={`${w640} 640w, ${w960} 960w, ${w1280} 1280w`}
        sizes="(max-width: 1200px) 92vw, 1040px"
      />
      <img
        class="ai-map-img"
        src={svg}
        alt="AI 领域关系图：人工智能包含机器学习与深度学习，并与计算机视觉、机器人、自然语言处理、语音识别交叉；外围连接数学、神经科学、计算机科学、心理学、生物学与物理学。"
        width="1200"
        height="780"
        decoding="async"
        loading="lazy"
        fetchpriority="low"
        draggable="false"
      />
    </picture>
    <figcaption class="ai-map-caption">
      示意图启发自经典 CS 课程讲义结构；本站用于帮助你理解工具与课程落在哪一层。
      <a href={roadmapHref} class="ai-map-link" data-track="home-ai-map-roadmap">查看学习路线 →</a>
    </figcaption>
  </figure>
</section>

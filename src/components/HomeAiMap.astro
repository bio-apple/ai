---
/**
 * 首页「AI 领域地图」— 内联 SVG 关系图
 * - 全部闭合 ellipse/circle；交叉靠半透明叠色
 * - 颜色只走 CSS class（不用 SVG 属性里的 var()，避免回退成纯黑）
 */
import { asset } from '../lib/paths';

const roadmapHref = asset('ai-learning-roadmap.html');
---

<section
  class="home-section fade-in home-ai-map"
  id="home-ai-map"
  aria-labelledby="home-ai-map-title"
>
  <div class="section-head">
    <p class="section-kicker">知识版图</p>
    <h2 class="section-title" id="home-ai-map-title">AI 领域如何层层嵌套</h2>
    <p class="section-desc">
      人工智能包含机器学习，再深入到深度学习；视觉、语音、机器人、NLP
      等应用交叉其中。外围是数学、神经科学等基础学科。
    </p>
  </div>

  <figure class="ai-map-figure">
    <div
      class="ai-map"
      role="img"
      aria-label="AI 领域关系图：人工智能包含机器学习与深度学习，并与计算机视觉、机器人、自然语言处理、语音识别交叉；外围连接数学、神经科学、计算机科学、心理学、生物学与物理学。"
    >
      <svg
        class="ai-map-svg"
        viewBox="0 0 1200 780"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        focusable="false"
      >
        <!-- connectors -->
        <g class="ai-map-connectors">
          <line x1="250" y1="118" x2="330" y2="200"></line>
          <line x1="600" y1="88" x2="600" y2="168"></line>
          <line x1="950" y1="118" x2="870" y2="200"></line>
          <line x1="250" y1="662" x2="340" y2="590"></line>
          <line x1="600" y1="692" x2="600" y2="620"></line>
          <line x1="950" y1="662" x2="860" y2="590"></line>
        </g>

        <!-- Artificial Intelligence -->
        <ellipse class="ai-map-ring-ai" cx="600" cy="390" rx="330" ry="255"></ellipse>
        <text class="ai-map-label-main" x="600" y="168" text-anchor="middle">人工智能</text>
        <text class="ai-map-label-sub" x="600" y="190" text-anchor="middle"
          >Artificial Intelligence</text
        >

        <!-- Machine Learning -->
        <ellipse class="ai-map-ring-ml" cx="620" cy="405" rx="220" ry="175"></ellipse>
        <text class="ai-map-label-main ai-map-label-md" x="620" y="268" text-anchor="middle"
          >机器学习</text
        >
        <text class="ai-map-label-sub" x="620" y="288" text-anchor="middle">Machine Learning</text>

        <!-- Deep Learning -->
        <circle class="ai-map-ring-dl" cx="640" cy="395" r="72"></circle>
        <text class="ai-map-label-main ai-map-label-sm" x="640" y="392" text-anchor="middle"
          >深度学习</text
        >
        <text class="ai-map-label-sub" x="640" y="412" text-anchor="middle">Deep Learning</text>

        <!-- Applications -->
        <ellipse class="ai-map-ring-app" cx="470" cy="360" rx="175" ry="58"></ellipse>
        <text class="ai-map-label-app" x="400" y="356" text-anchor="middle">计算机视觉</text>
        <text class="ai-map-label-sub" x="400" y="374" text-anchor="middle">Computer Vision</text>

        <ellipse class="ai-map-ring-app" cx="390" cy="305" rx="88" ry="62"></ellipse>
        <text class="ai-map-label-app" x="390" y="302" text-anchor="middle">机器人</text>
        <text class="ai-map-label-sub" x="390" y="320" text-anchor="middle">Robotics</text>

        <ellipse class="ai-map-ring-app" cx="610" cy="520" rx="168" ry="58"></ellipse>
        <text class="ai-map-label-app" x="610" y="516" text-anchor="middle">自然语言处理</text>
        <text class="ai-map-label-sub" x="610" y="534" text-anchor="middle"
          >Natural Language Processing</text
        >

        <ellipse class="ai-map-ring-app" cx="730" cy="455" rx="98" ry="48"></ellipse>
        <text class="ai-map-label-app" x="730" y="452" text-anchor="middle">语音识别</text>
        <text class="ai-map-label-sub" x="730" y="470" text-anchor="middle">Speech Recognition</text
        >

        <!-- Foundations -->
        <ellipse class="ai-map-ring-found" cx="250" cy="90" rx="92" ry="36"></ellipse>
        <text class="ai-map-label-found" x="250" y="86" text-anchor="middle">数学</text>
        <text class="ai-map-label-sub" x="250" y="104" text-anchor="middle">Mathematics</text>

        <ellipse class="ai-map-ring-found" cx="600" cy="58" rx="100" ry="36"></ellipse>
        <text class="ai-map-label-found" x="600" y="54" text-anchor="middle">神经科学</text>
        <text class="ai-map-label-sub" x="600" y="72" text-anchor="middle">Neuroscience</text>

        <ellipse class="ai-map-ring-found" cx="950" cy="90" rx="108" ry="36"></ellipse>
        <text class="ai-map-label-found" x="950" y="86" text-anchor="middle">计算机科学</text>
        <text class="ai-map-label-sub" x="950" y="104" text-anchor="middle">Computer Science</text>

        <ellipse class="ai-map-ring-found" cx="250" cy="690" rx="78" ry="34"></ellipse>
        <text class="ai-map-label-found" x="250" y="686" text-anchor="middle">物理学</text>
        <text class="ai-map-label-sub" x="250" y="704" text-anchor="middle">Physics</text>

        <ellipse class="ai-map-ring-found" cx="600" cy="720" rx="78" ry="34"></ellipse>
        <text class="ai-map-label-found" x="600" y="716" text-anchor="middle">生物学</text>
        <text class="ai-map-label-sub" x="600" y="734" text-anchor="middle">Biology</text>

        <ellipse class="ai-map-ring-found" cx="950" cy="690" rx="88" ry="34"></ellipse>
        <text class="ai-map-label-found" x="950" y="686" text-anchor="middle">心理学</text>
        <text class="ai-map-label-sub" x="950" y="704" text-anchor="middle">Psychology</text>
      </svg>
    </div>

    <figcaption class="ai-map-caption">
      圈均为闭合椭圆；交叉靠叠色表达。用层级理解工具与课程落在哪一层。
      <a href={roadmapHref} class="ai-map-link" data-track="home-ai-map-roadmap">查看学习路线 →</a>
    </figcaption>
  </figure>
</section>

---
import ThemeBoot from '../components/ThemeBoot.astro';
import SecurityMeta from '../components/SecurityMeta.astro';
import SeoHead from '../components/SeoHead.astro';
import Favicon from '../components/Favicon.astro';
import FontLoader from '../components/FontLoader.astro';
import UxWidgets from '../components/UxWidgets.astro';
import KnowledgeAssistant from '../components/KnowledgeAssistant.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../lib/data';
import { BASE, asset, assetVersioned, homeHref } from '../lib/paths';
import { stringifyJsonLd } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  canonical: string;
  schema?: object;
  scripts?: string[];
  ogType?: string;
  includeKnowledge?: boolean;
}

const {
  title,
  description,
  canonical,
  schema,
  scripts = [
    'vendor/fuse.min.js',
    'funnel.js',
    'analytics.js',
    'lib/link-guard.js',
    'ux.js',
    'app.js',
  ],
  ogType = 'article',
  includeKnowledge = false,
} = Astro.props;

const scriptList = [...scripts];
if (includeKnowledge && !scriptList.includes('vendor/fuse.min.js')) {
  scriptList.unshift('vendor/fuse.min.js');
}
const knowledgeSrc = includeKnowledge ? assetVersioned('knowledge.js') : '';
const knowledgeBoot = includeKnowledge
  ? `(function(){var loaded=false,src=${JSON.stringify(knowledgeSrc)};function load(){if(loaded||!src)return;loaded=true;var s=document.createElement('script');s.src=src;s.defer=true;document.body.appendChild(s);}function arm(){var fab=document.getElementById('knowledge-fab');if(!fab)return;['pointerenter','focus','touchstart'].forEach(function(ev){fab.addEventListener(ev,load,{once:true,passive:true});});}if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',arm);else arm();if('requestIdleCallback' in window)requestIdleCallback(function(){load();},{timeout:4000});else setTimeout(load,2500);})();`
  : '';

const styleHref = assetVersioned('style.css');
const home = homeHref();
---

<!doctype html>
<html lang="zh-CN" data-base={BASE}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SecurityMeta />
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      keywords={site.meta.keywords}
      ogType={ogType}
      ogImage={site.meta.og_image}
      ogImageAlt={site.meta.og_image_alt || title}
      siteName={site.meta.site_name || 'Bio AI Lab'}
    />
    <Favicon />
    <FontLoader />
    <style is:inline>
      html {
        overflow-x: hidden;
        max-width: 100%;
      }
      body {
        margin: 0;
        background: #eef3fb;
        color: #1a2234;
        font-family: system-ui, sans-serif;
      }
      #main-content {
        min-height: 40vh;
      }
    </style>
    <link rel="preload" href={styleHref} as="style" />
    <link rel="stylesheet" href={styleHref} />
    <ThemeBoot assetPrefix={BASE} />
    {schema && <script type="application/ld+json" set:html={stringifyJsonLd(schema)} />}
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <UxWidgets />
    {includeKnowledge && <KnowledgeAssistant />}
    <Nav nav={site.nav} standalone={true} homeHref={home} navPrefix={BASE} />
    <main id="main-content">
      <slot />
    </main>
    <Footer text={site.footer.text} />
    {knowledgeBoot && <script is:inline set:html={knowledgeBoot} />}
    {scriptList.map((src) => <script src={assetVersioned(src)} defer />)}
  </body>
</html>

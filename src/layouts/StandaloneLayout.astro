---
import ThemeBoot from '../components/ThemeBoot.astro';
import UxWidgets from '../components/UxWidgets.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../lib/data';
import { BASE, asset, homeHref } from '../lib/paths';

interface Props {
  title: string;
  description: string;
  canonical: string;
  schema?: object;
  scripts?: string[];
  ogType?: string;
}

const {
  title,
  description,
  canonical,
  schema,
  scripts = ['analytics.js', 'ux.js', 'app.js', 'progress.js'],
  ogType = 'article',
} = Astro.props;

const styleHref = asset('style.css');
const home = homeHref();
---
<!DOCTYPE html>
<html lang="zh-CN" data-base={BASE}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content={site.meta.keywords}>
  <link rel="canonical" href={canonical}>
  <meta property="og:type" content={ogType}>
  <meta property="og:url" content={canonical}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={site.meta.og_image}>
  <meta property="og:locale" content="zh_CN">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={site.meta.og_image}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700&family=Outfit:wght@450;550;650;750&display=swap" rel="stylesheet">
  <link rel="stylesheet" href={styleHref}>
  <ThemeBoot assetPrefix={BASE} />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
</head>
<body>
  <a class="skip-link" href="#main-content">跳到主要内容</a>
  <UxWidgets />
  <Nav nav={site.nav} standalone={true} homeHref={home} navPrefix={BASE} />
  <div id="main-content">
    <slot />
  </div>
  <Footer text={site.footer.text} github={site.footer.github} />
  {scripts.map((src) => <script src={asset(src)}></script>)}
</body>
</html>

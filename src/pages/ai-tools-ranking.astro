---
import StandaloneLayout from '../layouts/StandaloneLayout.astro';
import { site, rankings } from '../lib/data';
import { buildPageSchema } from '../lib/schema';
import { asset, homeHref } from '../lib/paths';

const base = site.meta.base_url;
const schema = buildPageSchema(
  `${rankings.title} | Bio AI Lab`,
  rankings.lead,
  `${base}ai-tools-ranking.html`,
);
const home = homeHref();
const boards = rankings.boards || [];
---

<StandaloneLayout
  title={`${rankings.title} | Bio AI Lab`}
  description={rankings.lead}
  canonical={`${base}ai-tools-ranking.html`}
  schema={schema}
  scripts={['analytics.js', 'ux.js', 'app.js', 'progress.js', 'ranking-tabs.js']}
>
  <main class="standalone-page ranking-page aicpb-ranking-page">
    <nav class="breadcrumb"><a href={home}>首页</a> / AI 工具排行榜</nav>

    <div class="standalone-hero aicpb-ranking-hero">
      <p class="section-kicker">每日更新 · {rankings.updated_at}</p>
      <h1>{rankings.title}</h1>
      <p class="standalone-lead">{rankings.lead}</p>
      <p class="standalone-meta">
        数据月份 {rankings.month_label || rankings.month} · 来源 AICPB · 各榜仅展示 Top 10
      </p>
    </div>

    <div class="aicpb-ranking-shell" data-ranking-tabs>
      <div class="aicpb-tabbar" role="tablist" aria-label="排行榜分类">
        {
          boards.map((board, index) => (
            <button
              type="button"
              class:list={['aicpb-tab', { 'is-active': index === 0 }]}
              data-ranking-tab={board.id}
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              aria-controls={`panel-${board.id}`}
            >
              {board.label}
            </button>
          ))
        }
      </div>

      {
        boards.map((board, index) => (
          <section
            id={`panel-${board.id}`}
            class="aicpb-board-panel"
            data-ranking-panel={board.id}
            role="tabpanel"
            aria-labelledby={`tab-${board.id}`}
            hidden={index !== 0}
          >
            <header class="aicpb-board-header">
              <h2>{board.title}</h2>
              <p>
                {board.subtitle} — {board.month}
              </p>
            </header>

            <div class="aicpb-table-wrap">
              <div class="aicpb-table-head" aria-hidden="true">
                <span>#排名</span>
                <span />
                <span>产品名</span>
                <span>访问量</span>
                <span>月环比</span>
              </div>
              <ol class="aicpb-table-body">
                {board.items.map((item) => (
                  <li class="aicpb-table-row">
                    <span class="aicpb-rank">{item.rank}</span>
                    <span class="aicpb-logo" aria-hidden="true">
                      {item.name.trim().charAt(0).toUpperCase()}
                    </span>
                    <div class="aicpb-product">
                      <a href={item.url} target="_blank" rel="noopener" class="aicpb-product-name">
                        {item.name}
                      </a>
                      {item.description ? (
                        <p class="aicpb-product-desc">{item.description}</p>
                      ) : null}
                    </div>
                    <span class="aicpb-visits">{item.visits}</span>
                    <div class="aicpb-mom">
                      <span class="aicpb-mom-value">{item.mom}</span>
                      <span class="aicpb-mom-bar-track" aria-hidden="true">
                        <em
                          class:list={[
                            'aicpb-mom-bar-fill',
                            item.mom.startsWith('-') ? 'is-down' : 'is-up',
                          ]}
                          style={`width:${item.mom_bar_pct || 0}%`}
                        />
                      </span>
                    </div>
                  </li>
                ))}
              </ol>
            </div>

            <div class="aicpb-board-footer">
              <a href={board.source_url} target="_blank" rel="noopener" class="aicpb-view-all">
                查看 {board.label} 全部产品 →
              </a>
            </div>
          </section>
        ))
      }
    </div>

    <section class="ranking-method aicpb-ranking-note" aria-label="引用说明">
      <h2 class="resources-title">引用说明</h2>
      <ul class="ranking-method-list">
        {rankings.methodology.map((line) => <li>{line}</li>)}
      </ul>
      <p class="aicpb-attribution">
        数据版权归 <a href="https://www.aicpb.com/" target="_blank" rel="noopener"
          >AICPB（AI产品榜）</a
        > 所有，本站仅作摘录展示。
      </p>
    </section>

    <div class="standalone-cta">
      <a href={home} class="cta-btn">返回首页</a>
      <a href={asset('tools/hub.html')} class="cta-btn cta-btn-outline">工具中心</a>
    </div>
  </main>
</StandaloneLayout>

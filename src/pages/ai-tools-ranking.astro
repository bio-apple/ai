---
import StandaloneLayout from '../layouts/StandaloneLayout.astro';
import StandalonePageHeader from '../components/StandalonePageHeader.astro';
import RankingBoardPanels from '../components/RankingBoardPanels.astro';
import { site, rankings } from '../lib/data';
import { buildPageSchema } from '../lib/schema';
import { asset, homeHref } from '../lib/paths';

const base = site.meta.base_url;
const schema = buildPageSchema(
  `${rankings.title} | Bio AI Lab`,
  rankings.lead,
  `${base}ai-tools-ranking.html`,
);
const home = homeHref();
const boards = (rankings.boards || []).map((board) => ({
  ...board,
  columns: board.columns || { name: '产品名', primary: '访问量', secondary: '月环比' },
  show_bar: board.show_bar !== false,
  source_name: board.source_name || board.label,
}));
---

<StandaloneLayout
  title={`${rankings.title} | Bio AI Lab`}
  description={rankings.lead}
  canonical={`${base}ai-tools-ranking.html`}
  schema={schema}
  scripts={['analytics.js', 'ux.js', 'app.js', 'ranking-tabs.js']}
>
  <main class="standalone-page ranking-page aicpb-ranking-page">
    <StandalonePageHeader
      crumbs={[{ label: '首页', href: home }, { label: 'AI 工具排行榜' }]}
      title={rankings.title}
      lead={rankings.lead}
      meta={`${rankings.month_label || rankings.month} · 三榜 Top 10 · 更新 ${rankings.updated_at}`}
      class="aicpb-ranking-hero"
    />

    <section class="page-section hub-ranking-section">
      <RankingBoardPanels boards={boards} panelIdPrefix="panel" headingLevel="h2" />
    </section>

    <section class="ranking-method aicpb-ranking-note page-section" aria-label="引用说明">
      <div class="section-head">
        <h2 class="section-title">引用说明</h2>
      </div>
      <ul class="ranking-method-list">
        {rankings.methodology.map((line) => <li>{line}</li>)}
      </ul>
      <p class="aicpb-attribution">
        数据版权归
        <a href="https://www.aicpb.com/" target="_blank" rel="noopener">AICPB</a>、
        <a href="https://arena.ai/leaderboard/text" target="_blank" rel="noopener"
          >LMSYS Chatbot Arena</a
        >、
        <a href="https://artificialanalysis.ai/leaderboards/models" target="_blank" rel="noopener"
          >Artificial Analysis</a
        >
        各自所有，本站仅作摘录展示。
      </p>
    </section>

    <div class="standalone-cta">
      <a href={home} class="cta-btn">返回首页</a>
      <a href={asset('tools/hub.html')} class="cta-btn cta-btn-outline">工具中心</a>
    </div>
  </main>
</StandaloneLayout>

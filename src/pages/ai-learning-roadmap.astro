---
import StandaloneLayout from '../layouts/StandaloneLayout.astro';
import StandalonePageHeader from '../components/StandalonePageHeader.astro';
import { site, toolNamesMap } from '../lib/data';
import { buildPageSchema } from '../lib/schema';
import { asset, homeHref } from '../lib/paths';

const page = site.roadmap_page;
const toolNames = toolNamesMap();
const base = site.meta.base_url;
const home = homeHref();
const breadcrumbs = [
  { name: '首页', url: `${base}` },
  { name: 'AI 学习路线', url: `${base}ai-learning-roadmap.html` },
];
const schema = buildPageSchema(
  page.title,
  page.lead,
  `${base}ai-learning-roadmap.html`,
  breadcrumbs,
);
---

<StandaloneLayout
  title={page.title}
  description={page.lead}
  canonical={`${base}ai-learning-roadmap.html`}
  schema={schema}
  ogType="website"
  scripts={['analytics.js', 'ux.js', 'app.js', 'progress.js']}
>
  <main class="standalone-page">
    <StandalonePageHeader
      crumbs={[{ label: '首页', href: home }, { label: 'AI 学习路线' }]}
      title={page.h1}
      lead={page.lead}
      meta={`进度 0/${page.phases.length}（保存在本浏览器）`}
      metaId="roadmap-progress-meta"
    />

    <section class="page-section">
      <div class="roadmap-timeline">
        {
          page.phases.map((phase, idx) => {
            const phaseId = `phase-${idx + 1}`;
            return (
              <article class="roadmap-phase card" data-phase-id={phaseId}>
                <div class="roadmap-phase-head">
                  <label class="roadmap-phase-done">
                    <input
                      type="checkbox"
                      class="roadmap-phase-check"
                      aria-label={`标记完成：${phase.title}`}
                    />
                    <span class="roadmap-phase-label">{phase.phase}</span>
                  </label>
                  <h2>{phase.title}</h2>
                </div>
                <div class="roadmap-tools">
                  {phase.tools.map((tid) => (
                    <a href={asset(`tools/${tid}.html`)} class={`roadmap-tool-chip ${tid}`}>
                      {toolNames[tid]}
                    </a>
                  ))}
                </div>
                <ul class="roadmap-tasks">
                  {phase.tasks.map((task) => (
                    <li>{task}</li>
                  ))}
                </ul>
              </article>
            );
          })
        }
      </div>
    </section>

    <div class="standalone-cta">
      <a href={asset('tools/hub.html')} class="cta-btn">浏览工具中心</a>
      <a href={asset('guides/beginner.html')} class="cta-btn cta-btn-outline">零基础指南</a>
      <a href={asset('ai-tools-ranking.html')} class="cta-btn cta-btn-outline">查看工具排行</a>
    </div>
  </main>
</StandaloneLayout>

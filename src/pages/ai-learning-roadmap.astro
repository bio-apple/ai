---
import StandaloneLayout from '../layouts/StandaloneLayout.astro';
import { site, toolNamesMap } from '../lib/data';
import { buildPageSchema } from '../lib/schema';
import { asset, homeHref } from '../lib/paths';

const page = site.roadmap_page;
const toolNames = toolNamesMap();
const base = site.meta.base_url;
const schema = buildPageSchema(page.title, page.lead, `${base}ai-learning-roadmap.html`);
const home = homeHref();
---
<StandaloneLayout
  title={page.title}
  description={page.lead}
  canonical={`${base}ai-learning-roadmap.html`}
  schema={schema}
>
  <main class="standalone-page">
    <nav class="breadcrumb"><a href={home}>首页</a> / AI 学习路线</nav>
    <div class="standalone-hero">
      <h1>{page.h1}</h1>
      <p class="standalone-lead">{page.lead}</p>
    </div>
    <div class="roadmap-timeline">
      {page.phases.map((phase) => (
        <article class="roadmap-phase card">
          <div class="roadmap-phase-head">
            <span class="roadmap-phase-label">{phase.phase}</span>
            <h2>{phase.title}</h2>
          </div>
          <div class="roadmap-tools">
            {phase.tools.map((tid) => (
              <a href={asset(`tools/${tid}.html`)} class={`roadmap-tool-chip ${tid}`}>{toolNames[tid]}</a>
            ))}
          </div>
          <ul class="roadmap-tasks">{phase.tasks.map((task) => <li>{task}</li>)}</ul>
        </article>
      ))}
    </div>
    <div class="standalone-cta">
      <a href={homeHref('#section-cases')} class="cta-btn">开始实战案例</a>
      <a href={asset('guides/beginner.html')} class="cta-btn cta-btn-outline">零基础指南</a>
      <a href={asset('ai-tools-ranking.html')} class="cta-btn cta-btn-outline">查看工具排行</a>
    </div>
  </main>
</StandaloneLayout>

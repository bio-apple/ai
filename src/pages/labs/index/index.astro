---
import StandaloneLayout from '../../../layouts/StandaloneLayout.astro';
import { site, toolLookup } from '../../../lib/data';
import { buildPageSchema } from '../../../lib/schema';
import { asset, homeHref } from '../../../lib/paths';

const page = site.labs_page;
const base = site.meta.base_url;
const schema = buildPageSchema(page.title, page.lead, `${base}labs/index.html`);
const lookup = toolLookup();
const urls = site.tool_urls || {};
const tools = Object.keys(urls).map((id) => ({
  id,
  name: (lookup[id] as { name?: string } | undefined)?.name || id,
  url: urls[id],
  tagline: (lookup[id] as { tagline?: string } | undefined)?.tagline || '',
}));
---
<StandaloneLayout
  title={page.title}
  description={page.lead}
  canonical={`${base}labs/index.html`}
  schema={schema}
  scripts={['analytics.js', 'ux.js', 'app.js', 'prompts.js']}
>
  <main class="standalone-page labs-page">
    <nav class="breadcrumb"><a href={homeHref()}>首页</a> / AI Labs</nav>
    <div class="standalone-hero">
      <h1>{page.h1}</h1>
      <p class="standalone-lead">{page.lead}</p>
    </div>

    <section class="labs-block" id="prompt-lab">
      <h2>Prompt Lab</h2>
      <p class="labs-desc">从案例提炼的可复制提示词；按分类筛选，一键复制实验。</p>
      <div class="section-cta">
        <a href={asset('prompts/library.html')} class="cta-btn">打开 Prompt 库 →</a>
        <a href={asset('cases/index.html')} class="cta-btn cta-btn-outline">实战案例 →</a>
      </div>
    </section>

    <section class="labs-block" id="model-lab">
      <h2>模型体验</h2>
      <p class="labs-desc">跳转到各产品官网体验（本站不托管模型推理）。</p>
      <div class="labs-model-grid">
        {tools.map((t) => (
          <a class="labs-model-card" href={t.url} target="_blank" rel="noopener" data-track={`lab-model-${t.id}`}>
            <strong>{t.name}</strong>
            <span>{t.tagline || '打开官网'}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="labs-block" id="agent-lab">
      <h2>Agent Playground</h2>
      <p class="labs-desc">轻量版：用站内知识库助手做工具问答与学习规划；完整 Agent 执行需自备 API。</p>
      <div class="section-cta">
        <a href={homeHref()} class="cta-btn" data-track="lab-knowledge">回首页打开知识库助手 →</a>
        <a href={asset('tools/hub.html')} class="cta-btn cta-btn-outline">浏览 Agent 类工具 →</a>
      </div>
    </section>

    <section class="labs-block" id="workflow-lab">
      <h2>个人工作流草稿</h2>
      <p class="labs-desc">本地编辑步骤列表，保存在浏览器；可导出 JSON 备份。</p>
      <div class="workflow-editor">
        <label for="workflow-title">工作流名称</label>
        <input id="workflow-title" class="workflow-input" type="text" maxlength="80" placeholder="例如：每周研究简报" />
        <label for="workflow-steps">步骤（每行一步）</label>
        <textarea id="workflow-steps" class="workflow-textarea" rows="8" placeholder="收集问题&#10;用 AI 检索与摘要&#10;整理成简报&#10;归档到知识库"></textarea>
        <div class="workflow-actions">
          <button type="button" class="cta-btn" id="workflow-save">保存到本地</button>
          <button type="button" class="cta-btn cta-btn-outline" id="workflow-export">导出 JSON</button>
          <button type="button" class="cta-btn cta-btn-outline" id="workflow-clear">清空</button>
        </div>
        <p class="workflow-status" id="workflow-status" aria-live="polite"></p>
      </div>
    </section>
  </main>

  <script is:inline>
    (function () {
      const KEY = 'bioai.workflow.v1';
      const title = document.getElementById('workflow-title');
      const steps = document.getElementById('workflow-steps');
      const status = document.getElementById('workflow-status');
      if (!title || !steps) return;
      try {
        const saved = JSON.parse(localStorage.getItem(KEY) || 'null');
        if (saved) {
          title.value = saved.title || '';
          steps.value = (saved.steps || []).join('\n');
        }
      } catch {}
      function payload() {
        return {
          title: title.value.trim(),
          steps: steps.value.split('\n').map((s) => s.trim()).filter(Boolean),
          updated_at: new Date().toISOString(),
        };
      }
      document.getElementById('workflow-save')?.addEventListener('click', () => {
        localStorage.setItem(KEY, JSON.stringify(payload()));
        if (status) status.textContent = '已保存到本浏览器';
      });
      document.getElementById('workflow-export')?.addEventListener('click', () => {
        const blob = new Blob([JSON.stringify(payload(), null, 2)], { type: 'application/json' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'bioai-workflow.json';
        a.click();
        URL.revokeObjectURL(a.href);
        if (status) status.textContent = '已导出 JSON';
      });
      document.getElementById('workflow-clear')?.addEventListener('click', () => {
        title.value = '';
        steps.value = '';
        localStorage.removeItem(KEY);
        if (status) status.textContent = '已清空';
      });
    })();
  </script>
</StandaloneLayout>

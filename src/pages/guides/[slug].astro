---
import StandaloneLayout from '../../layouts/StandaloneLayout.astro';
import StandalonePageHeader from '../../components/StandalonePageHeader.astro';
import { site } from '../../lib/data';
import { buildPageSchema } from '../../lib/schema';
import { asset, homeHref } from '../../lib/paths';

export function getStaticPaths() {
  return Object.entries(site.guides).map(([slug, guide]) => {
    const paths = site.learning_paths;
    const path = slug === 'advanced' && paths.length > 1 ? paths[1] : paths[0];
    return { params: { slug }, props: { guide, path } };
  });
}

const { guide, path } = Astro.props;
const base = site.meta.base_url;
const breadcrumbs = [
  { name: '首页', url: `${base}` },
  { name: '学习指南', url: `${base}ai-learning-roadmap.html` },
  { name: guide.h1, url: `${base}guides/${guide.slug}.html` },
];
const schema = buildPageSchema(
  guide.title,
  guide.lead,
  `${base}guides/${guide.slug}.html`,
  breadcrumbs,
);
const home = homeHref();
---

<StandaloneLayout
  title={guide.title}
  description={guide.lead}
  canonical={`${base}guides/${guide.slug}.html`}
  schema={schema}
>
  <main class="standalone-page">
    <StandalonePageHeader
      crumbs={[
        { label: '首页', href: home },
        { label: '学习指南', href: asset('ai-learning-roadmap.html') },
        { label: guide.h1 },
      ]}
      title={guide.h1}
      lead={guide.lead}
    />

    <section class="page-section">
      <div class="card">
        <h3><span class="dot" style={`background:${path.dot_color}`}></span> {path.title}</h3>
        <ol class="steps">{path.steps.map((step) => <li>{step}</li>)}</ol>
      </div>
    </section>

    <div class="standalone-cta">
      <a href={asset('tools/hub.html')} class="cta-btn">浏览工具中心</a>
      <a href={asset('ai-learning-roadmap.html')} class="cta-btn cta-btn-outline">完整学习路线</a>
    </div>
  </main>
</StandaloneLayout>

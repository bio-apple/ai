---
import StandaloneLayout from '../../../layouts/StandaloneLayout.astro';
import CasesSection from '../../../components/CasesSection.astro';
import { cases, site } from '../../../lib/data';
import { buildPageSchema } from '../../../lib/schema';
import { asset, homeHref } from '../../../lib/paths';

const page = site.cases_page;
const base = site.meta.base_url;
const breadcrumbs = [
  { name: '首页', url: `${base}` },
  { name: '实战案例库', url: `${base}cases/index.html` },
];
const schema = buildPageSchema(page.title, page.lead, `${base}cases/index.html`, breadcrumbs);
const home = homeHref();

let promptsCount = 0;
for (const caseItem of cases.cases) {
  for (const step of caseItem.steps || []) {
    promptsCount += (step.blocks || []).filter((b) => b.type === 'prompt').length;
  }
}
---

<StandaloneLayout
  title={page.title}
  description={page.lead}
  canonical={`${base}cases/index.html`}
  schema={schema}
  ogType="website"
>
  <main class="standalone-page">
    <nav class="breadcrumb"><a href={home}>首页</a> / 实战案例库</nav>
    <div class="standalone-hero">
      <h1>{page.h1}</h1>
      <p class="standalone-lead">{page.lead}</p>
      <p class="library-meta">{cases.cases.length} 个实战案例 · {promptsCount} 条 Prompt</p>
    </div>
    <CasesSection mode="page" />
    <div class="standalone-cta">
      <a href={asset('prompts/library.html')} class="cta-btn">Prompt 库</a>
      <a href={asset('labs/index.html')} class="cta-btn cta-btn-outline">AI Labs</a>
      <a href={home} class="cta-btn cta-btn-outline">回首页</a>
    </div>
  </main>
  <script is:inline>
    (function () {
      const params = new URLSearchParams(location.search);
      const anchor = params.get('anchor') || location.hash.replace(/^#/, '');
      if (!anchor) return;
      const el = document.getElementById(anchor);
      if (!el) return;
      el.classList.add('open');
      requestAnimationFrame(() => el.scrollIntoView({ behavior: 'smooth', block: 'start' }));
    })();
  </script>
</StandaloneLayout>

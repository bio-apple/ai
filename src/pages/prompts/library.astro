---
import StandaloneLayout from '../../layouts/StandaloneLayout.astro';
import { site } from '../../lib/data';
import { buildPageSchema } from '../../lib/schema';
import { homeHref, asset } from '../../lib/paths';
import promptLibraries from '../../../data/prompt-libraries.json';

const page = site.prompts_page;
const base = site.meta.base_url;
const schema = buildPageSchema(page.title, page.lead, `${base}prompts/library.html`);
const home = homeHref();
const libs = [...(promptLibraries.libraries || [])].map((lib, i) => ({
  ...lib,
  rank: lib.rank || i + 1,
}));

function formatStars(n: number) {
  if (!n) return '—';
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 10_000) return `${(n / 10_000).toFixed(1)}万`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(1)}K`;
  return String(n);
}
---

<StandaloneLayout
  title={page.title}
  description={page.lead}
  canonical={`${base}prompts/library.html`}
  schema={schema}
  scripts={['analytics.js', 'ux.js', 'app.js']}
>
  <main class="standalone-page prompt-libs-page">
    <nav class="breadcrumb"><a href={home}>首页</a> / Prompt 库</nav>

    <div class="standalone-hero">
      <p class="section-kicker">GitHub Stars · Top5 + 中文Top1</p>
      <h1>{page.h1}</h1>
      <p class="standalone-lead">{page.lead}</p>
      <p class="library-meta">按 Star 数排序 · 更新 {promptLibraries.updated_at}</p>
    </div>

    <ol class="prompt-libs-top5">
      {
        libs.map((lib) => (
          <li class="prompt-lib-card">
            <div class="prompt-lib-card-top">
              <span class="prompt-lib-rank">#{lib.rank}</span>
              <span class="prompt-libs-stars">★ {formatStars(lib.stars)}</span>
            </div>
            <h2 class="prompt-lib-card-name">
              <a href={lib.url} target="_blank" rel="noopener" data-track={`prompt-lib-${lib.id}`}>
                {lib.name}
              </a>
              {lib.badge ? <span class="oss-zh-badge">{lib.badge}</span> : null}
            </h2>
            <p class="prompt-libs-repo">
              {lib.repo}
              {lib.language ? ` · ${lib.language}` : ''}
            </p>
            <p class="prompt-libs-desc">{lib.description}</p>
            <a
              href={lib.url}
              target="_blank"
              rel="noopener"
              class="prompt-lib-cta"
              data-track={`prompt-lib-open-${lib.id}`}
            >
              打开仓库 →
            </a>
          </li>
        ))
      }
    </ol>

    <p class="library-attribution">
      {promptLibraries.source_note} 数据来自各仓库 GitHub 公开 Stars，本站仅作导航摘录。
    </p>

    <div class="standalone-cta">
      <a href={`${home}#section-oss`} class="cta-btn">开源精选</a>
      <a href={asset('tools/hub.html')} class="cta-btn cta-btn-outline">AI 工具中心</a>
    </div>
  </main>
</StandaloneLayout>

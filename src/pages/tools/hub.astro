---
import StandaloneLayout from '../../layouts/StandaloneLayout.astro';
import RankingBoardPanels from '../../components/RankingBoardPanels.astro';
import { site } from '../../lib/data';
import {
  buildHubCompareRows,
  buildHubRankingBoards,
  hubFeaturedCount,
  hubRankingMeta,
  HUB_RANKING_TOP_N,
} from '../../lib/hub';
import { buildPageSchema } from '../../lib/schema';
import { asset, homeHref } from '../../lib/paths';

const page = site.tools_hub_page;
const base = site.meta.base_url;
const breadcrumbs = [
  { name: '首页', url: `${base}` },
  { name: '工具中心', url: `${base}tools/hub.html` },
];
const schema = buildPageSchema(page.title, page.lead, `${base}tools/hub.html`, breadcrumbs);
const rows = buildHubCompareRows();
const boards = buildHubRankingBoards(HUB_RANKING_TOP_N).map((board) => ({
  ...board,
  subtitle: `${board.subtitle} · Top ${board.items.length}`,
}));
const toolCount = hubFeaturedCount();
const rankMeta = hubRankingMeta();
---

<StandaloneLayout
  title={page.title}
  description={page.lead}
  canonical={`${base}tools/hub.html`}
  schema={schema}
  ogType="website"
  scripts={['analytics.js', 'ux.js', 'app.js', 'ranking-tabs.js']}
>
  <main class="standalone-page tools-hub-page hub-compare-page aicpb-ranking-page">
    <nav class="breadcrumb"><a href={homeHref()}>首页</a> / 工具中心</nav>
    <div class="standalone-hero">
      <h1>{page.h1}</h1>
      <p class="standalone-lead">{page.lead}</p>
      <p class="standalone-meta">
        {toolCount} 款精选 · 多源排行更新 {rankMeta.updated_at}
      </p>
      <div class="hub-quick-links" aria-label="本页目录">
        <a href="#hub-compare" class="recommend-link">精选对比</a>
        <a href="#hub-ranking" class="recommend-link">多源排行</a>
      </div>
    </div>

    <section class="hub-compare-section" id="hub-compare" aria-labelledby="hub-compare-title">
      <div class="section-head">
        <h2 class="section-title" id="hub-compare-title">精选 AI 工具对比</h2>
        <p class="section-desc">类型、优势、场景与定价一表看清。</p>
      </div>

      <div class="hub-compare-wrap" role="region" aria-label="AI 工具对比表" tabindex="0">
        <table class="hub-compare-table">
          <thead>
            <tr>
              <th scope="col">工具</th>
              <th scope="col">类型</th>
              <th scope="col">核心优势</th>
              <th scope="col">适合场景</th>
              <th scope="col">定价</th>
            </tr>
          </thead>
          <tbody>
            {
              rows.map((row) => (
                <tr>
                  <th scope="row">
                    <span class="hub-compare-name">{row.name}</span>
                  </th>
                  <td>
                    <span class="hub-compare-type">{row.type}</span>
                  </td>
                  <td>{row.strength}</td>
                  <td>{row.scenario}</td>
                  <td>{row.pricing}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="hub-ranking-section" id="hub-ranking" aria-labelledby="hub-ranking-title">
      <div class="section-head">
        <h2 class="section-title" id="hub-ranking-title">AI 工具排行</h2>
        <p class="section-desc">
          AICPB · LMSYS Chatbot Arena Elo · Artificial Analysis Intelligence Index · Top {
            HUB_RANKING_TOP_N
          }
        </p>
      </div>

      <div class="hub-ranking-shell">
        <RankingBoardPanels
          boards={boards}
          panelIdPrefix="hub-panel"
          headingLevel="h3"
          footerSuffix="完整榜单 →"
        />
      </div>

      <p class="hub-ranking-footnote">
        完整 Top 10 与引用说明见
        <a href={asset('ai-tools-ranking.html')}>站内排行榜页</a>。
      </p>
    </section>

    <section class="ranking-method" aria-label="说明">
      <h2 class="resources-title">说明</h2>
      <ul class="ranking-method-list">
        <li>
          对比表用于能力与场景选型；排行仅展示 AICPB、LMSYS Chatbot Arena Elo、Artificial Analysis
          Intelligence Index 三榜。
        </li>
        <li>热度与榜单分数不等于适合你：先看场景与定价，再用排行交叉验证。</li>
      </ul>
      <p class="aicpb-attribution">
        数据版权归
        <a href="https://www.aicpb.com/" target="_blank" rel="noopener">AICPB</a>、
        <a href="https://arena.ai/leaderboard/text" target="_blank" rel="noopener">LMSYS Arena</a>、
        <a href="https://artificialanalysis.ai/leaderboards/models" target="_blank" rel="noopener"
          >Artificial Analysis</a
        >
        各自所有，本站仅作摘录展示。
      </p>
    </section>

    <div class="standalone-cta">
      <a href={homeHref()} class="cta-btn">返回首页</a>
      <a href={asset('ai-tools-ranking.html')} class="cta-btn cta-btn-outline">完整排行榜 →</a>
    </div>
  </main>
</StandaloneLayout>

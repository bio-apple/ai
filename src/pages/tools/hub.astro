---
import StandaloneLayout from '../../layouts/StandaloneLayout.astro';
import { rankings, site, tools } from '../../lib/data';
import { buildPageSchema } from '../../lib/schema';
import { asset, homeHref } from '../../lib/paths';

const page = site.tools_hub_page;
const base = site.meta.base_url;
const breadcrumbs = [
  { name: '首页', url: `${base}` },
  { name: '工具中心', url: `${base}tools/hub.html` },
];
const schema = buildPageSchema(page.title, page.lead, `${base}tools/hub.html`, breadcrumbs);
const boards = rankings.boards || [];

const NAME_ALIASES: Record<string, string> = {
  chatgpt: 'chatgpt',
  'new bing': 'new-bing',
  gemini: 'gemini',
  'google gemini': 'gemini',
  claude: 'claude',
  'claude｜anthropic': 'claude',
  'claude|anthropic': 'claude',
  deepseek: 'deepseek',
  'github copilot': 'copilot',
  'microsoft copilot': 'copilot',
  copilot: 'copilot',
  cursor: 'cursor',
  kimi: 'kimi',
  通义千问: 'qwen',
  qwen: 'qwen',
  豆包: 'doubao',
  'openai codex': 'codex',
  codex: 'codex',
};

function normalizeName(name: string) {
  return name.trim().toLowerCase().replace(/\s+/g, ' ');
}

function localToolId(name: string): string | null {
  const n = normalizeName(name);
  const baseName = n.split(/[|｜]/)[0].trim();
  const aliased = NAME_ALIASES[n] || NAME_ALIASES[baseName];
  if (aliased) return aliased;
  const hit = tools.find((t) => {
    const tn = normalizeName(t.name);
    return tn === n || tn === baseName || n.includes(tn) || tn.includes(baseName);
  });
  return hit?.id || null;
}
---

<StandaloneLayout
  title={page.title}
  description={page.lead}
  canonical={`${base}tools/hub.html`}
  schema={schema}
  ogType="website"
>
  <main class="standalone-page tools-hub-page aicpb-ranking-page">
    <nav class="breadcrumb"><a href={homeHref()}>首页</a> / 工具中心</nav>
    <div class="standalone-hero aicpb-ranking-hero">
      <p class="section-kicker">AICPB 各榜 Top 10 · 更新 {rankings.updated_at}</p>
      <h1>{page.h1}</h1>
      <p class="standalone-lead">{page.lead}</p>
      <p class="standalone-meta">
        数据月份 {rankings.month_label || rankings.month} · 来源 AICPB · 与排行榜同源
      </p>
      <div class="hub-quick-links">
        {
          boards.map((board) => (
            <a href={`#hub-${board.id}`} class="recommend-link">
              {board.label}
            </a>
          ))
        }
        <a
          href={asset('ai-tools-ranking.html')}
          class="recommend-link"
          data-track="hub-quick-ranking">排行榜页 →</a
        >
        <a
          href={asset('prompts/library.html')}
          class="recommend-link"
          data-track="hub-quick-prompts">Prompt 库 →</a
        >
      </div>
    </div>

    {
      boards.map((board) => (
        <section class="hub-category aicpb-hub-board" id={`hub-${board.id}`}>
          <header class="aicpb-board-header">
            <h2>{board.title}</h2>
            <p>
              {board.subtitle} — {board.month} · Top {board.items?.length || 0}
            </p>
          </header>

          <div class="aicpb-table-wrap">
            <div class="aicpb-table-head" aria-hidden="true">
              <span>#排名</span>
              <span />
              <span>产品名</span>
              <span>访问量</span>
              <span>月环比</span>
            </div>
            <ol class="aicpb-table-body">
              {(board.items || []).map((item) => {
                const toolId = localToolId(item.name);
                return (
                  <li class="aicpb-table-row">
                    <span class="aicpb-rank">{item.rank}</span>
                    <span class="aicpb-logo" aria-hidden="true">
                      {item.name.trim().charAt(0).toUpperCase()}
                    </span>
                    <div class="aicpb-product">
                      <a
                        href={item.url}
                        target="_blank"
                        rel="noopener"
                        class="aicpb-product-name"
                      >
                        {item.name}
                      </a>
                      {toolId ? (
                        <p class="hub-local-links">
                          <a
                            href={asset(`tools/${toolId}.html`)}
                            class="recommend-link"
                            data-track={`hub-local-${toolId}`}
                          >
                            站内教程 →
                          </a>
                        </p>
                      ) : null}
                    </div>
                    <span class="aicpb-visits">{item.visits}</span>
                    <div class="aicpb-mom">
                      <span class="aicpb-mom-value">{item.mom}</span>
                      <span class="aicpb-mom-bar-track" aria-hidden="true">
                        <em
                          class:list={[
                            'aicpb-mom-bar-fill',
                            item.mom.startsWith('-') ? 'is-down' : 'is-up',
                          ]}
                          style={`width:${item.mom_bar_pct || 0}%`}
                        />
                      </span>
                    </div>
                  </li>
                );
              })}
            </ol>
          </div>

          <div class="aicpb-board-footer">
            <a href={board.source_url} target="_blank" rel="noopener" class="aicpb-view-all">
              查看 {board.label} 全部产品 →
            </a>
          </div>
        </section>
      ))
    }

    <section class="ranking-method aicpb-ranking-note" aria-label="引用说明">
      <h2 class="resources-title">引用说明</h2>
      <ul class="ranking-method-list">
        {rankings.methodology.map((line) => <li>{line}</li>)}
      </ul>
      <p class="aicpb-attribution">
        数据版权归 <a href="https://www.aicpb.com/" target="_blank" rel="noopener"
          >AICPB（AI产品榜）</a
        > 所有，本站仅作摘录展示。
      </p>
    </section>

    <div class="standalone-cta">
      <a href={asset('ai-tools-ranking.html')} class="cta-btn">查看排行榜 →</a>
      <a href={asset('prompts/library.html')} class="cta-btn cta-btn-outline">Prompt 库 →</a>
    </div>
  </main>
</StandaloneLayout>

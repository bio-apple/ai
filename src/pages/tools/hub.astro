---
import StandaloneLayout from '../../layouts/StandaloneLayout.astro';
import { site } from '../../lib/data';
import { buildHubCompareRows, hubFeaturedCount } from '../../lib/hub';
import { buildPageSchema } from '../../lib/schema';
import { homeHref } from '../../lib/paths';

const page = site.tools_hub_page;
const base = site.meta.base_url;
const breadcrumbs = [
  { name: '首页', url: `${base}` },
  { name: '工具中心', url: `${base}tools/hub.html` },
];
const schema = buildPageSchema(page.title, page.lead, `${base}tools/hub.html`, breadcrumbs);
const rows = buildHubCompareRows();
const toolCount = hubFeaturedCount();
---

<StandaloneLayout
  title={page.title}
  description={page.lead}
  canonical={`${base}tools/hub.html`}
  schema={schema}
  ogType="website"
>
  <main class="standalone-page tools-hub-page hub-compare-page">
    <nav class="breadcrumb"><a href={homeHref()}>首页</a> / 工具中心</nav>
    <div class="standalone-hero">
      <p class="section-kicker">表格对比 · {toolCount} 款精选</p>
      <h1>{page.h1}</h1>
      <p class="standalone-lead">{page.lead}</p>
      <p class="standalone-meta">横向比较类型、优势、场景、定价与教程入口</p>
    </div>

    <section class="hub-compare-section" aria-labelledby="hub-compare-title">
      <div class="section-head">
        <h2 class="section-title" id="hub-compare-title">精选 AI 工具对比</h2>
        <p class="section-desc">同一表格并排比较，快速选型；点「官方教程 / 站内教程」继续深入。</p>
      </div>

      <div class="hub-compare-wrap" role="region" aria-label="AI 工具对比表" tabindex="0">
        <table class="hub-compare-table">
          <thead>
            <tr>
              <th scope="col">工具</th>
              <th scope="col">类型</th>
              <th scope="col">核心优势</th>
              <th scope="col">适合场景</th>
              <th scope="col">定价</th>
              <th scope="col">教程</th>
            </tr>
          </thead>
          <tbody>
            {
              rows.map((row) => (
                <tr>
                  <th scope="row">
                    <span class="hub-compare-name">{row.name}</span>
                  </th>
                  <td>
                    <span class="hub-compare-type">{row.type}</span>
                  </td>
                  <td>{row.strength}</td>
                  <td>{row.scenario}</td>
                  <td>{row.pricing}</td>
                  <td>
                    <div class="hub-compare-links">
                      {row.tutorialUrl ? (
                        <a
                          href={row.tutorialUrl}
                          target="_blank"
                          rel="noopener"
                          data-track={`hub-tutorial-${row.localId || row.name}`}
                        >
                          官方教程
                        </a>
                      ) : null}
                      {row.localHref ? (
                        <a href={row.localHref} data-track={`hub-local-${row.localId}`}>
                          站内教程
                        </a>
                      ) : null}
                      {row.siteUrl && row.siteUrl !== row.tutorialUrl ? (
                        <a
                          href={row.siteUrl}
                          target="_blank"
                          rel="noopener"
                          data-track={`hub-site-${row.localId || row.name}`}
                        >
                          官网
                        </a>
                      ) : null}
                    </div>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="ranking-method" aria-label="收录说明">
      <h2 class="resources-title">收录说明</h2>
      <ul class="ranking-method-list">
        <li>
          对比表仅含：ChatGPT、New Bing、Gemini、Claude｜Anthropic、DeepSeek、豆包｜抖音、Github
          Copilot、即梦 AI｜剪映、Kimi｜月之暗面、cursor。
        </li>
        <li>类型 / 优势 / 场景 / 定价为站内选型摘要。</li>
        <li>「官方教程」跳转厂商文档或帮助中心；有站内详解页时额外提供「站内教程」。</li>
      </ul>
    </section>

    <div class="standalone-cta">
      <a href={homeHref()} class="cta-btn">返回首页</a>
    </div>
  </main>
</StandaloneLayout>

---
import StandaloneLayout from '../../layouts/StandaloneLayout.astro';
import { rankings, site } from '../../lib/data';
import { buildHubAppCategories, HUB_TOP_N } from '../../lib/hub';
import { buildPageSchema } from '../../lib/schema';
import { asset, homeHref } from '../../lib/paths';

const page = site.tools_hub_page;
const base = site.meta.base_url;
const breadcrumbs = [
  { name: '首页', url: `${base}` },
  { name: '工具中心', url: `${base}tools/hub.html` },
];
const schema = buildPageSchema(page.title, page.lead, `${base}tools/hub.html`, breadcrumbs);
const categories = buildHubAppCategories(HUB_TOP_N);
const toolCount = categories.reduce((n, c) => n + c.items.length, 0);
---

<StandaloneLayout
  title={page.title}
  description={page.lead}
  canonical={`${base}tools/hub.html`}
  schema={schema}
  ogType="website"
>
  <main class="standalone-page tools-hub-page hub-app-page">
    <nav class="breadcrumb"><a href={homeHref()}>首页</a> / 工具中心</nav>
    <div class="standalone-hero">
      <p class="section-kicker">
        AICPB 各榜 Top {HUB_TOP_N} · 按应用分类 · 更新 {rankings.updated_at}
      </p>
      <h1>{page.h1}</h1>
      <p class="standalone-lead">{page.lead}</p>
      <p class="standalone-meta">
        {categories.length} 类应用 · {toolCount} 个工具 · 数据月份 {
          rankings.month_label || rankings.month
        }
      </p>
      <div class="hub-quick-links">
        {
          categories.map((cat) => (
            <a href={`#hub-${cat.id}`} class="recommend-link">
              {cat.label}
            </a>
          ))
        }
        <a
          href={asset('ai-tools-ranking.html')}
          class="recommend-link"
          data-track="hub-quick-ranking">完整排行榜 →</a
        >
      </div>
    </div>

    {
      categories.map((cat) => (
        <section class="hub-app-category" id={`hub-${cat.id}`}>
          <div class="section-head">
            <h2 class="section-title">{cat.label}</h2>
            <p class="section-desc">
              {cat.description} · 来源 AICPB {cat.boardLabel} Top {HUB_TOP_N}（{cat.month}）
            </p>
          </div>

          <div class="hub-app-grid">
            {cat.items.map((item) => (
              <article class="hub-app-card">
                <div class="hub-app-card-top">
                  <span class="hub-app-rank" aria-label={`第 ${item.rank} 名`}>
                    #{item.rank}
                  </span>
                  <div>
                    <h3 class="hub-app-name">{item.name}</h3>
                    <p class="hub-app-meta">
                      访问量 {item.visits}
                      {item.mom ? ` · 月环比 ${item.mom}` : ''}
                    </p>
                  </div>
                </div>
                <div class="hub-app-actions">
                  {item.tutorialUrl ? (
                    <a
                      href={item.tutorialUrl}
                      class="recommend-link"
                      target="_blank"
                      rel="noopener"
                      data-track={`hub-tutorial-${cat.id}-${item.rank}`}
                    >
                      {item.tutorialLabel} →
                    </a>
                  ) : null}
                  {item.siteUrl && item.siteUrl !== item.tutorialUrl ? (
                    <a
                      href={item.siteUrl}
                      class="recommend-link"
                      target="_blank"
                      rel="noopener"
                      data-track={`hub-site-${cat.id}-${item.rank}`}
                    >
                      官网 →
                    </a>
                  ) : null}
                  {item.localHref ? (
                    <a
                      href={item.localHref}
                      class="recommend-link"
                      data-track={`hub-local-${item.localId}`}
                    >
                      站内教程 →
                    </a>
                  ) : null}
                  <a
                    href={item.aicpbUrl}
                    class="recommend-link"
                    target="_blank"
                    rel="noopener"
                    data-track={`hub-aicpb-${cat.id}-${item.rank}`}
                  >
                    AICPB →
                  </a>
                </div>
              </article>
            ))}
          </div>

          <p class="hub-app-source">
            <a href={cat.sourceUrl} target="_blank" rel="noopener">
              查看 AICPB {cat.boardLabel} 完整榜单 →
            </a>
          </p>
        </section>
      ))
    }

    <section class="ranking-method aicpb-ranking-note" aria-label="引用说明">
      <h2 class="resources-title">引用说明</h2>
      <ul class="ranking-method-list">
        <li>
          内容来自 AICPB 五个专题榜各 Top {HUB_TOP_N}，再按应用归类：助手 / 编程 / 视频 / PPT。
        </li>
        <li>每个工具优先展示官方教程；若有站内详解页则额外提供「站内教程」。</li>
        <li>完整 Top 10 与访问量明细见站内排行榜页；数据版权归 AICPB 所有。</li>
      </ul>
      <p class="aicpb-attribution">
        数据版权归 <a href="https://www.aicpb.com/" target="_blank" rel="noopener"
          >AICPB（AI产品榜）</a
        > 所有，本站仅作摘录展示。
      </p>
    </section>

    <div class="standalone-cta">
      <a href={asset('ai-tools-ranking.html')} class="cta-btn">查看完整排行榜 →</a>
      <a href={asset('prompts/library.html')} class="cta-btn cta-btn-outline">Prompt 库 →</a>
    </div>
  </main>
</StandaloneLayout>

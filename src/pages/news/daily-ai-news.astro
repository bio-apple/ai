---
import StandaloneLayout from '../../layouts/StandaloneLayout.astro';
import StandalonePageHeader from '../../components/StandalonePageHeader.astro';
import { site } from '../../lib/data';
import { buildNewsSchema, mergeSchemaGraphs, buildPageSchema } from '../../lib/schema';
import { homeHref } from '../../lib/paths';
import newsPayload from '../../../ai-news.json';

const page = site.news_page;
const base = site.meta.base_url;
const breadcrumbs = [
  { name: '首页', url: `${base}` },
  { name: '新闻热点', url: `${base}news/daily-ai-news.html` },
];
const schema = mergeSchemaGraphs(
  buildPageSchema(page.title, page.lead, `${base}news/daily-ai-news.html`, breadcrumbs),
  buildNewsSchema(
    { title: page.h1 || page.title, lead: page.lead, items: newsPayload.items || [] },
    base,
  ),
);
const home = homeHref();
---

<StandaloneLayout
  title={`${page.title} | Bio AI Lab`}
  description={page.lead}
  canonical={`${base}news/daily-ai-news.html`}
  schema={schema}
  scripts={[
    'lib/fetch-json.js',
    'lib/link-guard.js',
    'vendor/fuse.min.js',
    'funnel.js',
    'analytics.js',
    'ux.js',
    'app.js',
    'news.js',
  ]}
>
  <main class="standalone-page">
    <StandalonePageHeader
      crumbs={[{ label: '首页', href: home }, { label: '新闻热点' }]}
      title={page.h1}
      lead={page.lead}
      metaId="news-page-meta"
    />

    <section class="page-section">
      <div id="daily-news-list" class="news-list">
        <p class="loading-hint">加载 AI 新闻…</p>
      </div>
    </section>

    <div class="standalone-cta">
      <a href={homeHref('#section-news')} class="cta-btn">返回站内新闻</a>
      <a href={home} class="cta-btn cta-btn-outline">返回首页</a>
    </div>
  </main>
</StandaloneLayout>

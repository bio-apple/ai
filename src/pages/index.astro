---
import HomeLayout from '../layouts/HomeLayout.astro';
import HomeRecommend from '../components/HomeRecommend.astro';
import HomeAiDaily from '../components/HomeAiDaily.astro';
import HomeOps from '../components/HomeOps.astro';
import GlobalSearch from '../components/GlobalSearch.astro';
import HomeQuickFilters from '../components/HomeQuickFilters.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import HomeAiMap from '../components/HomeAiMap.astro';
import HomeLocalDeploy from '../components/HomeLocalDeploy.astro';
import { site } from '../lib/data';
import {
  buildHomeSchema,
  buildCoursesSchema,
  buildLocalDeploySchema,
  mergeSchemaGraphs,
} from '../lib/schema';
import { asset, homeHref } from '../lib/paths';
import coursesPayload from '../../ai-courses.json';
import localDeployPayload from '../../data/local-deploy.json';

const homeCrumb = { label: '首页', href: homeHref(), tool: 'all' };

const schema = mergeSchemaGraphs(
  buildHomeSchema(site),
  buildCoursesSchema(coursesPayload, site.meta.canonical),
  buildLocalDeploySchema(localDeployPayload, site.meta.canonical),
);
---

<HomeLayout
  title={site.meta.title}
  description={site.meta.description}
  canonical={site.meta.canonical}
  schema={schema}
  scripts={[
    'lib/fetch-json.js',
    'lib/virtual-list.js',
    'vendor/fuse.min.js',
    'funnel.js',
    'analytics.js',
    'lib/link-guard.js',
    'ux.js',
    'app.js',
    'recommend.js',
    'engagement.js',
    'lazy-sections.js',
  ]}
  includeKnowledge={true}
>
  <section id="section-home" class="section active">
    <div class="hero">
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-grid"></div>
        <div class="hero-orb hero-orb-a"></div>
        <div class="hero-orb hero-orb-b"></div>
      </div>
      <div class="hero-content">
        <div class="hero-brand-mark">
          <span class="hero-logo-icon" aria-hidden="true">{site.nav.logo.icon}</span>
          <p class="hero-brand">{site.hero.eyebrow}</p>
        </div>
        <h1>{site.hero.title}</h1>
        <p class="hero-subtitle">{site.hero.subtitle}</p>
        <div class="hero-cta">
          <a
            href={site.hero.cta_primary?.href || '#home-recommend'}
            class="cta-btn"
            data-track="hero-cta-primary">{site.hero.cta_primary?.label || '获取 AI 推荐'}</a
          >
        </div>
        <p class="hero-secondary-link">
          <a
            href={asset(site.hero.cta_secondary?.href || 'tools/hub.html')}
            data-track="hero-cta-nav">{site.hero.cta_secondary?.label || '浏览工具中心'} →</a
          >
        </p>
        <GlobalSearch variant="hero" />
        <HomeQuickFilters />
      </div>
    </div>

    <div class="home-main">
      <HomeRecommend />
      <HomeAiDaily />
      <HomeAiMap />

      <section
        class="home-section fade-in"
        id="home-community"
        aria-labelledby="home-community-title"
      >
        <div class="section-head">
          <h2 class="section-title" id="home-community-title">AI 工具中心</h2>
        </div>
        <div class="community-links">
          <a
            href={asset('tools/hub.html')}
            class="community-card"
            data-track="home-community-hub"
            aria-label="进入 AI 工具中心"
          >
            <span class="community-card-kicker">对比 · 排行</span>
            <strong>AI 工具中心</strong>
            <span>精选对比表与三榜排行（AICPB / LMSYS / AA）。</span>
            <em class="community-card-cta">浏览工具 →</em>
          </a>
        </div>
      </section>

      <HomeOps />
    </div>
  </section>

  <section id="section-local" class="section local-section">
    <div class="section-panel">
      <Breadcrumb crumbs={[homeCrumb, { label: '本地部署' }]} />
      <div class="tool-header">
        <div class="tool-icon" style="background:rgba(37,99,235,0.12);color:var(--accent)">⌂</div>
        <div>
          <h2>本地部署</h2>
          <p class="desc">{localDeployPayload.lead}</p>
        </div>
      </div>
      <HomeLocalDeploy />
    </div>
  </section>

  <section id="section-courses" class="section courses-section">
    <noscript><p class="loading-hint error-hint">请启用 JavaScript 以加载课程资源。</p></noscript>
    <div class="section-panel">
      <Breadcrumb crumbs={[homeCrumb, { label: '课程资源' }]} />
      <div class="tool-header">
        <div class="tool-icon" style="background:rgba(37,99,235,0.12);color:var(--accent)">📚</div>
        <div>
          <h2>AI 课程资源</h2>
          <p class="desc" id="courses-lead">
            按学习路线精选免费课：微软与谷歌入门，斯坦福 CS230 / CS231n / CS224n / CS336（YouTube
            最新学年讲座 + 官网）。
          </p>
          <p class="video-update-meta" id="courses-update-meta"></p>
        </div>
      </div>
      <div class="video-toolbar" id="courses-toolbar"></div>
      <div id="courses-list" class="courses-list">
        <p class="loading-hint">加载课程资源…</p>
      </div>
    </div>
  </section>

  <section id="section-news" class="section">
    <div class="section-panel">
      <Breadcrumb crumbs={[homeCrumb, { label: '新闻热点' }]} />
      <div class="tool-header">
        <div class="tool-icon" style="background:rgba(37,99,235,0.12);color:var(--accent)">📰</div>
        <div>
          <h2>一周内 AI 热点</h2>
          <p class="desc">近 7 天热点，按分类浏览。</p>
          <p class="video-update-meta" id="news-update-meta"></p>
        </div>
      </div>
      <div id="daily-news-list" class="news-list">
        <noscript><p class="loading-hint error-hint">请启用 JavaScript 以加载新闻。</p></noscript>
        <p class="loading-hint">加载 AI 新闻…</p>
      </div>
      <div id="news-watch-sources" class="news-watch-sources"></div>
      <div class="section-cta">
        <a href={asset('news/daily-ai-news.html')} class="cta-btn cta-btn-outline"
          >查看新闻归档页 →</a
        >
      </div>
    </div>
  </section>

  <section id="section-videos" class="section videos-section">
    <div class="section-panel">
      <Breadcrumb crumbs={[homeCrumb, { label: 'AI 视频' }]} />
      <div class="tool-header">
        <div class="tool-icon" style="background:rgba(37,99,235,0.12);color:var(--accent)">▶</div>
        <div>
          <h2>近期热门AI视频推荐</h2>
          <p class="desc">
            YouTube 与 B站分别列出近 30 天内播放量 Top10 的 AI 相关视频（≥10
            万播放），按播放量排序，日更。
          </p>
          <p class="video-update-meta" id="video-update-meta"></p>
        </div>
      </div>
      <div class="video-toolbar" id="video-toolbar">
        <div class="video-toolbar-group">
          <span class="video-toolbar-label">平台</span>
          <button
            type="button"
            class="video-filter active"
            data-video-platform="all"
            aria-pressed="true">全部</button
          >
          <button
            type="button"
            class="video-filter"
            data-video-platform="youtube"
            aria-pressed="false">YouTube</button
          >
          <button
            type="button"
            class="video-filter"
            data-video-platform="bilibili"
            aria-pressed="false">B站</button
          >
        </div>
        <div class="video-toolbar-group">
          <span class="video-toolbar-label">排序</span>
          <button
            type="button"
            class="video-sort active"
            data-video-sort="views"
            aria-pressed="true">热门</button
          >
          <button type="button" class="video-sort" data-video-sort="recent" aria-pressed="false"
            >最新</button
          >
        </div>
      </div>
      <div id="daily-video-list" class="daily-video-list">
        <noscript><p class="loading-hint error-hint">请启用 JavaScript 以加载视频。</p></noscript>
        <p class="loading-hint">加载视频推荐…</p>
      </div>
    </div>
  </section>
</HomeLayout>

---
import HomeLayout from '../layouts/HomeLayout.astro';
import ToolSection from '../components/ToolSection.astro';
import HomeOssPreview from '../components/HomeOssPreview.astro';
import HomeRecommend from '../components/HomeRecommend.astro';
import HomeAiDaily from '../components/HomeAiDaily.astro';
import HomeOps from '../components/HomeOps.astro';
import { site, tools } from '../lib/data';
import { buildHomeSchema } from '../lib/schema';
import { asset } from '../lib/paths';

const schema = buildHomeSchema(site);
---

<HomeLayout
  title={site.meta.title}
  description={site.meta.description}
  canonical={site.meta.canonical}
  schema={schema}
  scripts={[
    'vendor/fuse.min.js',
    'analytics.js',
    'ux.js',
    'app.js',
    'recommend.js',
    'progress.js',
    'engagement.js',
    'lazy-sections.js',
  ]}
  includeKnowledge={true}
>
  <section id="section-home" class="section active">
    <div class="hero">
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-grid"></div>
        <div class="hero-orb hero-orb-a"></div>
        <div class="hero-orb hero-orb-b"></div>
      </div>
      <div class="hero-content">
        <div class="hero-brand-mark">
          <span class="hero-logo-icon" aria-hidden="true">{site.nav.logo.icon}</span>
          <p class="hero-brand">{site.hero.eyebrow}</p>
        </div>
        <h1>{site.hero.title}</h1>
        <p class="hero-subtitle">{site.hero.subtitle}</p>
        <div class="hero-cta">
          <a
            href={site.hero.cta_primary?.href || '#home-recommend'}
            class="cta-btn"
            data-track="hero-cta-primary">{site.hero.cta_primary?.label || '获取 AI 推荐'}</a
          >
          <a
            href={site.hero.cta_github?.href || site.footer.github}
            class="github-star-btn"
            target="_blank"
            rel="noopener"
            data-track={site.hero.cta_github?.track || 'github-star-hero'}
          >
            <span aria-hidden="true">★</span>
            {site.hero.cta_github?.label || 'Star on GitHub'}
          </a>
        </div>
        <p class="hero-secondary-link">
          <a
            href={asset(site.hero.cta_secondary?.href || 'tools/hub.html')}
            data-track="hero-cta-nav">{site.hero.cta_secondary?.label || '浏览工具中心'} →</a
          >
        </p>
        <div class="site-search-wrap hero-search">
          <label class="hero-search-label" for="site-search">全站搜索</label>
          <input
            type="search"
            id="site-search"
            class="site-search"
            placeholder={site.hero.search_placeholder}
            aria-label="站内搜索"
            data-search-ready="0"
            data-search-status="loading"
          />
          <div id="site-search-results" class="site-search-results" hidden></div>
        </div>
      </div>
    </div>

    <main class="home-main">
      <HomeRecommend />
      <HomeAiDaily />

      <section class="home-section fade-in" id="home-oss">
        <div class="section-head">
          <h2 class="section-title">开源项目精选</h2>
          <p class="section-desc">每领域代表项目 · 完整列表在开源专区</p>
        </div>
        <HomeOssPreview />
        <div class="section-cta">
          <button class="cta-btn cta-btn-outline" data-goto="oss" data-track="home-all-oss"
            >查看全部开源项目 →</button
          >
        </div>
      </section>

      <section class="home-section fade-in" id="home-community">
        <div class="section-head">
          <p class="section-kicker">继续深入</p>
          <h2 class="section-title">工具 · 排行 · 案例</h2>
          <p class="section-desc">主路径：推荐 → 简报 → 工具中心；案例详情在独立页</p>
        </div>
        <div class="community-links">
          <a href={asset('tools/hub.html')} class="community-card" data-track="home-community-hub">
            <strong>工具</strong>
            <span>分类目录 · Prompt 库 · 工作流入口</span>
          </a>
          <a
            href={asset('ai-tools-ranking.html')}
            class="community-card"
            data-track="home-community-rank"
          >
            <strong>2026 工具排行榜</strong>
            <span>按月 · 用户量 · 模型能力 · 价格</span>
          </a>
          <a
            href={asset('cases/index.html')}
            class="community-card"
            data-track="home-community-cases"
          >
            <strong>实战案例</strong>
            <span>独立页 · Prompt 库</span>
          </a>
        </div>
        <div class="section-cta compare-guide-grid" style="margin-top:1.25rem">
          {
            site.compare_guides.map((g) => (
              <a href={asset(g.href)} class="compare-guide-card" data-track={g.track}>
                <span class="compare-guide-tag">{g.tag}</span>
                <h4>{g.title}</h4>
                <p>{g.description}</p>
              </a>
            ))
          }
        </div>
      </section>

      <HomeOps />
    </main>
  </section>

  {tools.map((tool) => <ToolSection tool={tool} />)}

  <section id="section-oss" class="section oss-section">
    <noscript><p class="loading-hint error-hint">请启用 JavaScript 以加载开源精选。</p></noscript>
    <main>
      <div class="tool-header">
        <div class="tool-icon" style="background:rgba(37,99,235,0.12);color:var(--accent)">⭐</div>
        <div>
          <h2>GitHub Stars 开源精选</h2>
          <p class="desc">六领域代表仓库，Star 数每周刷新。首页仅展示抽样。</p>
          <p class="video-update-meta" id="oss-update-meta"></p>
        </div>
      </div>
      <div id="oss-project-list" class="oss-project-list">
        <p class="loading-hint">加载 GitHub 开源精选…</p>
      </div>
    </main>
  </section>

  <section id="section-news" class="section">
    <main>
      <div class="tool-header">
        <div class="tool-icon" style="background:rgba(37,99,235,0.12);color:var(--accent)">📰</div>
        <div>
          <h2>一周内 AI 热点</h2>
          <p class="desc">每天更新 · 覆盖近 7 天 · 按分类浏览；点击标题阅读原文。</p>
          <p class="video-update-meta" id="news-update-meta"></p>
        </div>
      </div>
      <div id="daily-news-list" class="news-list">
        <noscript><p class="loading-hint error-hint">请启用 JavaScript 以加载新闻。</p></noscript>
        <p class="loading-hint">加载 AI 新闻…</p>
      </div>
      <div id="news-watch-sources" class="news-watch-sources"></div>
      <div class="section-cta">
        <a href={asset('news/daily-ai-news.html')} class="cta-btn cta-btn-outline"
          >查看新闻归档页 →</a
        >
      </div>
    </main>
  </section>

  <section id="section-videos" class="section videos-section">
    <main>
      <div class="tool-header">
        <div class="tool-icon" style="background:rgba(37,99,235,0.12);color:var(--accent)">▶</div>
        <div>
          <h2>每日 AI 视频推荐</h2>
          <p class="desc">
            日更完整列表：YouTube / B站各自合并展示，默认按上传时间排序。上方简报仅摘 2 条。
          </p>
          <p class="video-update-meta" id="video-update-meta"></p>
        </div>
      </div>
      <div class="video-toolbar" id="video-toolbar">
        <div class="video-toolbar-group">
          <span class="video-toolbar-label">平台</span>
          <button type="button" class="video-filter active" data-video-platform="all">全部</button>
          <button type="button" class="video-filter" data-video-platform="youtube">YouTube</button>
          <button type="button" class="video-filter" data-video-platform="bilibili">B站</button>
        </div>
        <div class="video-toolbar-group">
          <span class="video-toolbar-label">排序</span>
          <button type="button" class="video-sort" data-video-sort="views">热门</button>
          <button type="button" class="video-sort active" data-video-sort="recent">最新</button>
        </div>
      </div>
      <div id="daily-video-list" class="daily-video-list">
        <noscript><p class="loading-hint error-hint">请启用 JavaScript 以加载视频。</p></noscript>
        <p class="loading-hint">加载视频推荐…</p>
      </div>
    </main>
  </section>
</HomeLayout>

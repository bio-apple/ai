---
import HomeLayout from '../layouts/HomeLayout.astro';
import ToolSection from '../components/ToolSection.astro';
import CasesSection from '../components/CasesSection.astro';
import HomeOssPreview from '../components/HomeOssPreview.astro';
import HomeRecommend from '../components/HomeRecommend.astro';
import HomeAiDaily from '../components/HomeAiDaily.astro';
import HomeFavorites from '../components/HomeFavorites.astro';
import {
  site, tools, buildHotToolCards,
} from '../lib/data';
import { buildHomeSchema } from '../lib/schema';
import { asset } from '../lib/paths';

const hotToolCards = buildHotToolCards();
const schema = buildHomeSchema(site);

const recommendKind: Record<string, string> = {
  '最推荐': 'top',
  '新手必学': 'beginner',
  '开发者': 'dev',
  '企业版': 'enterprise',
  '免费': 'free',
};
---
<HomeLayout
  title={site.meta.title}
  description={site.meta.description}
  canonical={site.meta.canonical}
  schema={schema}
  scripts={['vendor/fuse.min.js', 'analytics.js', 'ux.js', 'app.js', 'recommend.js', 'favorites.js', 'lazy-sections.js']}
  includeKnowledge={true}
>
  <section id="section-home" class="section active">
    <div class="hero">
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-grid"></div>
        <div class="hero-orb hero-orb-a"></div>
        <div class="hero-orb hero-orb-b"></div>
      </div>
      <div class="hero-content fade-in">
        <div class="hero-brand-mark">
          <span class="hero-logo-icon" aria-hidden="true">{site.nav.logo.icon}</span>
          <p class="hero-brand">{site.hero.eyebrow}</p>
        </div>
        <h1>{site.hero.title}</h1>
        <p class="hero-subtitle">{site.hero.subtitle}</p>
        <div class="hero-cta">
          <button class="cta-btn" data-goto={site.hero.cta_primary.goto} data-track="hero-cta-primary">{site.hero.cta_primary.label}</button>
          <a href={site.hero.cta_secondary.href} class="cta-btn cta-btn-outline" data-track="hero-cta-nav">{site.hero.cta_secondary.label}</a>
        </div>
        <div class="site-search-wrap hero-search">
          <label class="hero-search-label" for="site-search">全站搜索</label>
          <input type="search" id="site-search" class="site-search" placeholder={site.hero.search_placeholder} aria-label="站内搜索">
          <div id="site-search-results" class="site-search-results" hidden></div>
        </div>
      </div>
    </div>

    <main class="home-main">
      <HomeRecommend />
      <HomeAiDaily />
      <HomeFavorites />

      <section class="home-section fade-in" id="home-tools">
        <div class="section-head">
          <h2 class="section-title">热门 AI 工具</h2>
          <p class="section-desc">优先推荐 · 三秒定位你要学的工具</p>
        </div>
        <div class="tool-cards tool-cards-grid tool-cards-hot">
          {hotToolCards.map((tool) => (
            <article class={`tool-card-v2 ${tool.id}`} data-tool={tool.id}>
              <div class="tool-card-top">
                <div class={`tool-card-logo ${tool.id}`}>{tool.icon}</div>
                <span class="badge">{tool.badge}</span>
                <button type="button" class="fav-star" data-fav-toggle={tool.id} aria-label="收藏工具" aria-pressed="false" title="收藏工具">☆</button>
              </div>
              {(tool.recommend || []).length > 0 && (
                <ul class="recommend-badges">
                  {tool.recommend.map((r) => (
                    <li class="recommend-badge" data-kind={recommendKind[r] || 'top'}>{r}</li>
                  ))}
                </ul>
              )}
              <h3>{tool.name}</h3>
              <p class="tool-tagline">{tool.tagline}</p>
              <ul class="tool-tags">{tool.tags.map((tag) => <li>{tag}</li>)}</ul>
              <button type="button" class="tool-card-btn" data-tool={tool.id}>查看教程 →</button>
            </article>
          ))}
        </div>
      </section>

      <section class="home-section fade-in" id="home-learning">
        <div class="section-head">
          <p class="section-kicker">学习路线</p>
          <h2 class="section-title">AI 学习路线</h2>
          <p class="section-desc">从入门对话到进阶工作流，按阶段推进</p>
        </div>
        <div class="learning-grid">
          {site.learning_paths.map((pathItem) => (
            <article class="learning-card">
              <h3 style={`border-color:${pathItem.dot_color}`}>{pathItem.title}</h3>
              <ol>
                {pathItem.steps.map((step) => <li>{step}</li>)}
              </ol>
            </article>
          ))}
        </div>
        <div class="section-cta">
          <a href={asset('guides/beginner.html')} class="cta-btn cta-btn-outline" data-track="home-guide-beginner">零基础指南 →</a>
          <a href={asset('guides/advanced.html')} class="cta-btn cta-btn-outline" data-track="home-guide-advanced">进阶指南 →</a>
          <a href={asset('ai-learning-roadmap.html')} class="cta-btn cta-btn-outline" data-track="home-roadmap">完整路线图 →</a>
        </div>
      </section>

      <section class="home-section fade-in" id="home-categories">
        <div class="section-head">
          <h2 class="section-title">AI 工具导航</h2>
          <p class="section-desc">按国内 / 国际与编程场景浏览全部工具</p>
        </div>
        {site.home_tool_categories.map((cat) => (
          <>
            <p class="category-label">{cat.label}</p>
            <div class="tool-cards tool-cards-grid">
              {cat.tools.map((tool) => (
                <article class={`tool-card-v2 ${tool.id}`} data-tool={tool.id}>
                  <div class="tool-card-top">
                    <div class={`tool-card-logo ${tool.id}`}>{tool.icon}</div>
                    <span class="badge">{tool.badge}</span>
                  </div>
                  {(tool.recommend || []).length > 0 && (
                    <ul class="recommend-badges">
                      {tool.recommend.map((r) => (
                        <li class="recommend-badge" data-kind={recommendKind[r] || 'top'}>{r}</li>
                      ))}
                    </ul>
                  )}
                  <h3>{tool.name}</h3>
                  <p class="tool-tagline">{tool.tagline}</p>
                  <p class="tool-summary">{tool.summary}</p>
                  <ul class="tool-tags">{tool.tags.map((tag) => <li>{tag}</li>)}</ul>
                  <button type="button" class="tool-card-btn" data-tool={tool.id}>查看教程 →</button>
                </article>
              ))}
            </div>
          </>
        ))}
      </section>

      <section class="home-section fade-in" id="home-oss">
        <div class="section-head">
          <h2 class="section-title">开源项目精选</h2>
          <p class="section-desc">六大领域代表项目，Star 数每周刷新</p>
        </div>
        <HomeOssPreview />
        <div class="section-cta">
          <button class="cta-btn cta-btn-outline" data-goto="oss" data-track="home-all-oss">查看全部开源项目 →</button>
        </div>
      </section>

      <section class="home-section fade-in" id="home-community">
        <div class="section-head">
          <p class="section-kicker">社区动态</p>
          <h2 class="section-title">继续深入</h2>
          <p class="section-desc">排行榜、选型对比、完整新闻与视频推荐</p>
        </div>
        <div class="community-links">
          <a href={asset('tools/hub.html')} class="community-card" data-track="home-community-hub">
            <strong>AI 工具中心</strong>
            <span>助手 · 编程 · 写作 · 图片 · Agent</span>
          </a>
          <a href={asset('labs/index.html')} class="community-card" data-track="home-community-labs">
            <strong>AI Labs</strong>
            <span>Prompt · 模型体验 · 工作流草稿</span>
          </a>
          <a href={asset('ai-tools-ranking.html')} class="community-card" data-track="home-community-rank">
            <strong>2026 工具排行榜</strong>
            <span>综合能力 · 长文本 · 性价比 · 编程</span>
          </a>
          <a href={asset('cases/index.html')} class="community-card" data-track="home-community-cases">
            <strong>实战案例 & Prompt</strong>
            <span>跟着任务流程掌握工具</span>
          </a>
          <button type="button" class="community-card" data-goto="news" data-track="home-community-news">
            <strong>本周 AI 热点</strong>
            <span>官方博客 · Trending · 中文媒体</span>
          </button>
          <button type="button" class="community-card" data-goto="videos" data-track="home-community-videos">
            <strong>每日 AI 视频</strong>
            <span>YouTube / B站 六类推荐</span>
          </button>
        </div>
        <div class="section-cta compare-guide-grid" style="margin-top:1.25rem">
          {site.compare_guides.map((g) => (
            <a href={g.href} class="compare-guide-card" data-track={g.track}>
              <span class="compare-guide-tag">{g.tag}</span>
              <h4>{g.title}</h4>
              <p>{g.description}</p>
            </a>
          ))}
        </div>
      </section>
    </main>
  </section>

  {tools.map((tool) => <ToolSection tool={tool} />)}

  <CasesSection />

  <section id="section-oss" class="section oss-section">
    <main>
      <div class="tool-header">
        <div class="tool-icon" style="background:rgba(37,99,235,0.12);color:var(--accent)">⭐</div>
        <div>
          <h2>GitHub Stars 开源精选</h2>
          <p class="desc">六大 AI 应用领域各至少收录 1 个代表项目：AI Agent、LLM 应用开发、本地大模型、AI 绘画、多模态、机器学习框架。Star 数每周刷新。</p>
          <p class="video-update-meta" id="oss-update-meta"></p>
        </div>
      </div>
      <div id="oss-project-list" class="oss-project-list">
        <p class="loading-hint">加载 GitHub 开源精选…</p>
      </div>
    </main>
  </section>

  <section id="section-news" class="section">
    <main>
      <div class="tool-header">
        <div class="tool-icon" style="background:rgba(37,99,235,0.12);color:var(--accent)">📰</div>
        <div>
          <h2>本周 AI 热点</h2>
          <p class="desc">每周更新一次。关注 OpenAI、Anthropic、Google DeepMind、Meta AI、Microsoft AI、NVIDIA AI、Hugging Face（公告 + X）；GitHub Trending；arXiv cs.AI / cs.LG / cs.CL / cs.CV；中文渠道机器之心、量子位、新智元、智源社区。</p>
          <p class="video-update-meta" id="news-update-meta"></p>
        </div>
      </div>
      <div id="daily-news-list" class="news-list">
        <p class="loading-hint">加载 AI 新闻…</p>
      </div>
      <div id="news-watch-sources" class="news-watch-sources"></div>
      <div class="section-cta">
        <a href={asset('news/daily-ai-news.html')} class="cta-btn cta-btn-outline">查看新闻归档页 →</a>
      </div>
    </main>
  </section>

  <section id="section-videos" class="section videos-section">
    <main>
      <div class="tool-header">
        <div class="tool-icon" style="background:rgba(37,99,235,0.12);color:var(--accent)">▶</div>
        <div>
          <h2>每日 AI 视频推荐</h2>
          <p class="desc">每日北京时间 0:00 更新六类（展示 100d → 30d → 24h）：YouTube / B站 100 天全网播放量 Top 10、30 天内上新 Top 5、24 小时内上新 Top 3。</p>
          <p class="video-update-meta" id="video-update-meta"></p>
        </div>
      </div>
      <div class="video-toolbar" id="video-toolbar">
        <div class="video-toolbar-group">
          <span class="video-toolbar-label">平台</span>
          <button type="button" class="video-filter active" data-video-platform="all">全部</button>
          <button type="button" class="video-filter" data-video-platform="youtube">YouTube</button>
          <button type="button" class="video-filter" data-video-platform="bilibili">B站</button>
        </div>
        <div class="video-toolbar-group">
          <span class="video-toolbar-label">排序</span>
          <button type="button" class="video-sort active" data-video-sort="views">热门</button>
          <button type="button" class="video-sort" data-video-sort="recent">最新</button>
        </div>
      </div>
      <div id="daily-video-list" class="daily-video-list">
        <p class="loading-hint">加载视频推荐…</p>
      </div>
    </main>
  </section>
</HomeLayout>

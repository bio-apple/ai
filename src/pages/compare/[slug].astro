---
import StandaloneLayout from '../../layouts/StandaloneLayout.astro';
import StandalonePageHeader from '../../components/StandalonePageHeader.astro';
import { compares, site } from '../../lib/data';
import { buildCompareSchema } from '../../lib/schema';
import { asset, homeHref } from '../../lib/paths';

export function getStaticPaths() {
  return compares.map((compare) => ({ params: { slug: compare.slug }, props: { compare } }));
}

const { compare } = Astro.props;
const base = site.meta.base_url;
const breadcrumbs = [
  { name: '首页', url: `${base}` },
  { name: '选型指南', url: `${base}ai-tools-ranking.html` },
  { name: compare.breadcrumb, url: `${base}compare/${compare.slug}.html` },
];
const schema = buildCompareSchema(compare, base, breadcrumbs);
const home = homeHref();
---

<StandaloneLayout
  title={compare.title}
  description={compare.meta_description}
  canonical={`${base}compare/${compare.slug}.html`}
  schema={schema}
>
  <main class="standalone-page">
    <StandalonePageHeader
      crumbs={[
        { label: '首页', href: home },
        { label: '选型指南', href: asset('ai-tools-ranking.html') },
        { label: compare.breadcrumb },
      ]}
      title={compare.h1}
      lead={compare.lead}
    />

    <div class="answer-box">
      <strong>一句话结论：</strong><span set:html={compare.conclusion} />
    </div>

    <section class="page-section" aria-labelledby="compare-table-title">
      <div class="section-head">
        <h2 class="section-title" id="compare-table-title">参数对比</h2>
      </div>
      <div class="table-wrap" role="region" aria-label="工具对比表" tabindex="0">
        <table class="compare-table">
          <thead><tr>{compare.table.headers.map((h) => <th>{h}</th>)}</tr></thead>
          <tbody>
            {
              compare.table.rows.map((row) => (
                <tr>
                  {row.map((cell) => (
                    <td>{cell}</td>
                  ))}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    {
      compare.sections.map((sec) => (
        <section class="page-section" aria-labelledby={`compare-sec-${sec.heading}`}>
          <div class="section-head">
            <h2 class="section-title" id={`compare-sec-${sec.heading}`}>
              {sec.heading}
            </h2>
          </div>
          {sec.ordered ? (
            <ol class="steps">
              {sec.items.map((item) => (
                <li set:html={item} />
              ))}
            </ol>
          ) : (
            <ul class="features">
              {sec.items.map((item) => (
                <li set:html={item} />
              ))}
            </ul>
          )}
        </section>
      ))
    }

    <div class="standalone-cta">
      {
        compare.cta.map((btn) => (
          <a
            href={btn.href}
            class:list={['cta-btn', { 'cta-btn-outline': btn.outline }]}
            data-track={btn.track}
          >
            {btn.label}
          </a>
        ))
      }
    </div>
  </main>
</StandaloneLayout>

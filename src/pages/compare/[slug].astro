---
import StandaloneLayout from '../../layouts/StandaloneLayout.astro';
import { compares, site } from '../../lib/data';
import { buildCompareSchema } from '../../lib/schema';
import { homeHref } from '../../lib/paths';

export function getStaticPaths() {
  return compares.map((compare) => ({ params: { slug: compare.slug }, props: { compare } }));
}

const { compare } = Astro.props;
const base = site.meta.base_url;
const schema = buildCompareSchema(compare, base);
const home = homeHref();
---
<StandaloneLayout
  title={compare.title}
  description={compare.meta_description}
  canonical={`${base}compare/${compare.slug}.html`}
  schema={schema}
>
  <main class="standalone-page">
    <nav class="breadcrumb"><a href={home}>首页</a> / 选型指南 / {compare.breadcrumb}</nav>
    <h1>{compare.h1}</h1>
    <p class="standalone-lead">{compare.lead}</p>
    <div class="answer-box"><strong>一句话结论：</strong><span set:html={compare.conclusion} /></div>
    <table class="compare-table">
      <thead><tr>{compare.table.headers.map((h) => <th>{h}</th>)}</tr></thead>
      <tbody>{compare.table.rows.map((row) => <tr>{row.map((cell) => <td>{cell}</td>)}</tr>)}</tbody>
    </table>
    {compare.sections.map((sec) => (
      <>
        <h2>{sec.heading}</h2>
        {sec.ordered ? (
          <ol class="steps">{sec.items.map((item) => <li set:html={item} />)}</ol>
        ) : (
          <ul class="features">{sec.items.map((item) => <li set:html={item} />)}</ul>
        )}
      </>
    ))}
    <div class="standalone-cta">
      {compare.cta.map((btn) => (
        <a href={btn.href} class:list={['cta-btn', { 'cta-btn-outline': btn.outline }]} data-track={btn.track}>{btn.label}</a>
      ))}
    </div>
  </main>
</StandaloneLayout>

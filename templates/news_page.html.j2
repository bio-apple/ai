<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page.title }}</title>
  <meta name="description" content="{{ page.lead }}">
  <meta name="keywords" content="AI新闻,OpenAI,Anthropic,DeepMind,Hugging Face,大模型">
  <link rel="canonical" href="{{ meta.base_url }}news/daily-ai-news.html">
  <meta property="og:title" content="{{ page.title }}">
  <meta property="og:description" content="{{ page.lead }}">
  <meta property="og:image" content="{{ meta.og_image }}">
  <meta property="og:url" content="{{ meta.base_url }}news/daily-ai-news.html">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../style.css">
  <script type="application/ld+json">{{ schema_json | safe }}</script>
</head>
<body>
{% with standalone=true, home_href='../index.html', nav_prefix='../' %}
{% include 'partials/nav.j2' %}
{% endwith %}
<main class="standalone-page">
  <nav class="breadcrumb"><a href="../index.html">首页</a> / AI 新闻</nav>
  <div class="standalone-hero">
    <h1>{{ page.h1 }}</h1>
    <p class="standalone-lead">{{ page.lead }}</p>
    <p class="standalone-meta" id="news-page-meta"></p>
  </div>
  <div id="daily-news-list" class="news-list">
    <p class="loading-hint">加载 AI 新闻…</p>
  </div>
  <div class="standalone-cta">
    <a href="../index.html#section-news" class="cta-btn">返回站内新闻</a>
    <a href="../index.html" class="cta-btn cta-btn-outline">返回首页</a>
  </div>
</main>
<footer>
  <p>{{ footer.text }} · <a href="{{ footer.github }}" target="_blank" rel="noopener">GitHub</a></p>
</footer>
<script src="../analytics.js"></script>
<script src="../app.js"></script>
<script src="../news.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ meta.title }}</title>
  <meta name="description" content="{{ meta.description }}">
  <meta name="keywords" content="{{ meta.keywords }}">
  <link rel="canonical" href="{{ meta.canonical }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ meta.canonical }}">
  <meta property="og:title" content="Bio AI Lab 2026 — AI 学习与工具导航平台">
  <meta property="og:description" content="{{ meta.description }}">
  <meta property="og:image" content="{{ meta.og_image }}">
  <meta property="og:locale" content="zh_CN">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Bio AI Lab 2026 — AI 学习与工具导航平台">
  <meta name="twitter:description" content="{{ meta.description }}">
  <meta name="twitter:image" content="{{ meta.og_image }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
  <script type="application/ld+json">{{ schema_json | safe }}</script>
</head>
<body>

{% with standalone=false, home_href='index.html', nav_prefix='' %}
{% include 'partials/nav.j2' %}
{% endwith %}

<section id="section-home" class="section active">
  <div class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-content fade-in">
      <div class="hero-brand-mark">
        <span class="hero-eyebrow">{{ hero.eyebrow }}</span>
        <span class="hero-logo-icon">{{ nav.logo.icon }}</span>
      </div>
      <h1>{{ hero.title }}</h1>
      <p class="hero-subtitle">{{ hero.subtitle }}</p>
      <div class="hero-cta">
        <button class="cta-btn" data-goto="{{ hero.cta_primary.goto }}" data-track="hero-cta-primary">{{ hero.cta_primary.label }}</button>
        <a href="{{ hero.cta_secondary.href }}" class="cta-btn cta-btn-outline" data-track="hero-cta-ranking">{{ hero.cta_secondary.label }}</a>
      </div>
      <div class="site-search-wrap">
        <input type="search" id="site-search" class="site-search" placeholder="{{ hero.search_placeholder }}" aria-label="站内搜索">
        <div id="site-search-results" class="site-search-results" hidden></div>
      </div>
    </div>
  </div>

  <main class="home-main">
    <section class="home-section fade-in">
      <div class="section-head">
        <h2 class="section-title">热门 AI 工具</h2>
        <p class="section-desc">30 秒内找到最适合你的 AI 助手</p>
      </div>
      <div class="tool-cards-scroll">
        <div class="tool-cards tool-cards-hot">
          {% for tool in hot_tool_cards %}
          <article class="tool-card-v2 {{ tool.id }}" data-tool="{{ tool.id }}">
            <div class="tool-card-logo {{ tool.id }}">{{ tool.icon }}</div>
            <span class="badge">{{ tool.badge }}</span>
            <h3>{{ tool.name }}</h3>
            <p class="tool-tagline">{{ tool.tagline }}</p>
            <div class="tool-stars" aria-label="推荐指数 {{ tool.stars }} 星">{% for i in range(tool.stars) %}★{% endfor %}{% for i in range(5 - tool.stars) %}<span class="star-empty">★</span>{% endfor %}</div>
            <ul class="tool-tags">{% for tag in tool.tags %}<li>{{ tag }}</li>{% endfor %}</ul>
            <button type="button" class="tool-card-btn" data-tool="{{ tool.id }}">查看详情</button>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>

    <section class="home-section fade-in">
      <div class="section-head">
        <h2 class="section-title">AI 能力分类</h2>
        <p class="section-desc">按场景浏览全部工具</p>
      </div>
      {% for cat in home_tool_categories %}
      <p class="category-label">{{ cat.label }}</p>
      <div class="tool-cards-scroll">
        <div class="tool-cards">
          {% for tool in cat.tools %}
          <article class="tool-card-v2 {{ tool.id }}" data-tool="{{ tool.id }}">
            <div class="tool-card-logo {{ tool.id }}">{{ tool.icon }}</div>
            <span class="badge">{{ tool.badge }}</span>
            <h3>{{ tool.name }}</h3>
            <p class="tool-tagline">{{ tool.tagline }}</p>
            <p class="tool-summary">{{ tool.summary }}</p>
            <div class="tool-stars" aria-label="推荐指数 {{ tool.stars }} 星">{% for i in range(tool.stars) %}★{% endfor %}{% for i in range(5 - tool.stars) %}<span class="star-empty">★</span>{% endfor %}</div>
            <ul class="tool-tags">{% for tag in tool.tags %}<li>{{ tag }}</li>{% endfor %}</ul>
            <button type="button" class="tool-card-btn" data-tool="{{ tool.id }}">查看详情</button>
          </article>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </section>

    <section class="home-section fade-in" id="home-rankings">
      <div class="section-head">
        <h2 class="section-title">2026 AI 工具排行榜</h2>
        <p class="section-desc">综合能力、长文本、性价比、编程体验</p>
      </div>
      <div class="ranking-grid">
        {% for item in rankings %}
        <article class="ranking-card" data-tool="{{ item.id }}">
          <span class="ranking-medal">{{ item.medal }}</span>
          <h3>{{ item.name }}</h3>
          <p class="ranking-dimension">{{ item.dimension }}</p>
          <p class="ranking-score">{{ item.score }}</p>
          <div class="tool-stars">{% for i in range(item.stars) %}★{% endfor %}</div>
          <button type="button" class="tool-card-btn tool-card-btn-sm" data-tool="{{ item.id }}">查看教程</button>
        </article>
        {% endfor %}
      </div>
      <div class="section-cta">
        <a href="ai-tools-ranking.html" class="cta-btn cta-btn-outline" data-track="home-full-ranking">查看完整排行榜 →</a>
      </div>
    </section>

    <section class="home-section fade-in">
      <div class="section-head">
        <h2 class="section-title">AI 学习路线</h2>
        <p class="section-desc">从零基础到进阶应用的系统路径</p>
      </div>
      <div class="grid-2">
        {% for path in learning_paths %}
        <div class="card">
          <h3><span class="dot" style="background:{{ path.dot_color }}"></span> {{ path.title }}</h3>
          <ol class="steps">
            {% for step in path.steps %}<li>{{ step }}</li>{% endfor %}
          </ol>
        </div>
        {% endfor %}
      </div>
      <div class="section-cta">
        <a href="guides/beginner.html" class="cta-btn cta-btn-outline">入门指南</a>
        <a href="ai-learning-roadmap.html" class="cta-btn cta-btn-outline" data-track="home-roadmap">完整学习路线 →</a>
      </div>
    </section>

    <section class="home-section fade-in" id="home-news">
      <div class="section-head">
        <h2 class="section-title">今日 AI 热点</h2>
        <p class="section-desc">OpenAI · Anthropic · DeepMind · Hugging Face 官方动态</p>
      </div>
      <div id="home-news-preview" class="home-news-preview">
        <p class="loading-hint">加载今日热点…</p>
      </div>
      <div class="section-cta">
        <button class="cta-btn cta-btn-outline" data-goto="news" data-track="home-all-news">查看全部 AI 新闻 →</button>
      </div>
    </section>

    <section class="home-section fade-in" id="ai-picker">
      <div class="section-head">
        <h2 class="section-title">{{ ai_picker.title }}</h2>
        <p class="section-desc">选择你的目标，获取工具推荐</p>
      </div>
      <div class="ai-picker">
        <div class="ai-picker-options" role="radiogroup" aria-label="{{ ai_picker.title }}">
          {% for opt in ai_picker.options %}
          <button type="button" class="ai-picker-option{% if loop.first %} active{% endif %}" data-picker="{{ opt.id }}" aria-pressed="{% if loop.first %}true{% else %}false{% endif %}">
            <span class="ai-picker-icon">{{ opt.icon }}</span>
            <span>{{ opt.label }}</span>
          </button>
          {% endfor %}
        </div>
        <div class="ai-picker-result">
          <p class="ai-picker-label">推荐工具</p>
          <div class="ai-picker-tools">
            {% for opt in ai_picker.options %}
            <div class="ai-picker-tool-group{% if loop.first %} active{% endif %}" data-picker-result="{{ opt.id }}">
              {% for tid in opt.tools %}
              <button type="button" class="ai-picker-tool {{ tid }}" data-tool="{{ tid }}">{{ tool_names[tid] }}</button>
              {% endfor %}
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </section>

    <section class="home-section fade-in">
      <div class="section-head">
        <h2 class="section-title">精选教程与视频</h2>
        <p class="section-desc">选型对比、实战案例与每日教程视频</p>
      </div>
      <div class="compare-guide-grid">
        {% for g in compare_guides %}
        <a href="{{ g.href }}" class="compare-guide-card" data-track="{{ g.track }}">
          <span class="compare-guide-tag">{{ g.tag }}</span>
          <h4>{{ g.title }}</h4>
          <p>{{ g.description }}</p>
        </a>
        {% endfor %}
      </div>
      <div id="home-video-preview" class="home-video-preview">
        <p class="loading-hint">加载今日精选…</p>
      </div>
      <div class="section-cta">
        <button class="cta-btn" data-goto="cases" data-track="home-cases">查看实战案例 →</button>
        <button class="cta-btn cta-btn-outline" data-goto="videos" data-track="home-all-videos">每日视频 →</button>
      </div>
    </section>
  </main>
</section>

{% for tool in tools %}
{% include 'partials/tool_section.j2' %}
{% endfor %}

{% include 'partials/cases_section.j2' %}

{% include 'partials/create_section.j2' %}

{% include 'partials/news_section.j2' %}

<section id="section-videos" class="section videos-section">
  <main>
    <div class="tool-header">
      <div class="tool-icon" style="background:rgba(37,99,235,0.12);color:var(--accent)">▶</div>
      <div>
        <h2>每日 AI 视频推荐</h2>
        <p class="desc">每日北京时间 0:00 自动更新，从 YouTube 与 B站 抓取 AI 教程，分四类推荐：YouTube 全网播放量 Top 10、YouTube 24 小时内上新 Top 10、B站 全网播放量 Top 10、B站 24 小时内上新 Top 10。</p>
        <p class="video-update-meta" id="video-update-meta"></p>
      </div>
    </div>
    <div id="daily-video-list" class="daily-video-list">
      <p class="loading-hint">加载视频推荐…</p>
    </div>
  </main>
</section>

<footer>
  <p>{{ footer.text }} · <a href="{{ footer.github }}" target="_blank" rel="noopener">GitHub</a></p>
</footer>

<script src="analytics.js"></script>
<script src="app.js"></script>
<script src="news.js"></script>
<script src="videos.js"></script>
</body>
</html>

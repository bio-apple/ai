<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page.title }}</title>
  <meta name="description" content="{{ page.lead }}">
  <meta name="keywords" content="AI实战,案例,教程,ChatGPT,Cursor,Claude">
  <link rel="canonical" href="{{ meta.base_url }}cases/index.html">
  <meta property="og:title" content="{{ page.title }}">
  <meta property="og:description" content="{{ page.lead }}">
  <meta property="og:image" content="{{ meta.og_image }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../style.css">
  {% include 'partials/theme_boot.j2' %}
  <script type="application/ld+json">{{ schema_json | safe }}</script>
</head>
<body>
{% include 'partials/ux_widgets.j2' %}
{% with standalone=true, home_href='../index.html', nav_prefix='../' %}
{% include 'partials/nav.j2' %}
{% endwith %}
<main class="standalone-page">
  <nav class="breadcrumb"><a href="../index.html">首页</a> / 实战案例库</nav>
  <div class="standalone-hero">
    <h1>{{ page.h1 }}</h1>
    <p class="standalone-lead">{{ page.lead }}</p>
    <p class="library-meta">{{ tutorials.count }} 个实战案例 · {{ prompts_count }} 条 Prompt</p>
  </div>
  <div class="library-toolbar" id="cases-toolbar">
    <button type="button" class="library-filter active" data-case-tool="all">全部工具</button>
    {% for tid in cases.tool_filters if tid != 'all' %}
    <button type="button" class="library-filter" data-case-tool="{{ tid }}">{{ tool_names.get(tid, tid) }}</button>
    {% endfor %}
  </div>
  <div class="cases-library-grid">
    {% for t in tutorials.tutorials %}
    <article class="case-library-card reveal" data-tool="{{ t.tool }}">
      <div class="case-library-head">
        <span class="case-badge {{ t.tool }}">{{ t.tool_name }}</span>
        <span class="case-level">{{ t.level }}</span>
      </div>
      <h3>{{ t.title }}</h3>
      <p>{{ t.summary }}</p>
      <div class="case-library-meta">
        <span>{{ t.duration }}</span>
        <span>{{ t.prompt_count }} 条 Prompt</span>
      </div>
      <a href="../index.html?anchor={{ t.id }}#section-cases" class="case-library-link">查看完整步骤 →</a>
    </article>
    {% endfor %}
  </div>
  <div class="standalone-cta">
    <a href="../index.html#section-cases" class="cta-btn">站内案例区</a>
    <a href="../prompts/library.html" class="cta-btn cta-btn-outline">Prompt 库</a>
  </div>
</main>
<footer>
  <p>{{ footer.text }} · <a href="{{ footer.github }}" target="_blank" rel="noopener">GitHub</a></p>
</footer>
<script src="../analytics.js"></script>
<script src="../ux.js"></script>
<script src="../app.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page.title }}</title>
  <meta name="description" content="{{ page.lead }}">
  <link rel="canonical" href="{{ meta.base_url }}ai-tools-ranking.html">
  <meta property="og:title" content="{{ page.title }}">
  <meta property="og:description" content="{{ page.lead }}">
  <meta property="og:image" content="{{ meta.og_image }}">
  <meta property="og:url" content="{{ meta.base_url }}ai-tools-ranking.html">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
  <script type="application/ld+json">{{ schema_json | safe }}</script>
</head>
<body>
{% with standalone=true, home_href='index.html', nav_prefix='' %}
{% include 'partials/nav.j2' %}
{% endwith %}
<main class="standalone-page">
  <nav class="breadcrumb"><a href="index.html">首页</a> / AI 工具排行榜</nav>
  <div class="standalone-hero">
    <h1>{{ page.h1 }}</h1>
    <p class="standalone-lead">{{ page.lead }}</p>
    <p class="standalone-meta">更新于 {{ page.updated }}</p>
  </div>

  <div class="ranking-grid ranking-grid-full">
    {% for item in rankings %}
    <article class="ranking-card ranking-card-lg">
      <span class="ranking-medal">{{ item.medal }}</span>
      <h2>{{ item.name }}</h2>
      <p class="ranking-dimension">{{ item.dimension }}</p>
      <p class="ranking-score">{{ item.score }}</p>
      <div class="tool-stars">{% for i in range(item.stars) %}★{% endfor %}</div>
      <a href="tools/{{ item.id }}.html" class="cta-btn cta-btn-sm">查看 {{ item.name }} 教程</a>
    </article>
    {% endfor %}
  </div>

  <h2 class="resources-title">完整工具对比表</h2>
  <div class="compare-wrap">
    <table class="compare-table">
      <thead>
        <tr><th>工具</th><th>类型</th><th>核心优势</th><th>适合场景</th><th>入门</th></tr>
      </thead>
      <tbody>
        {% for row in compare_table.rows %}
        <tr>
          <td>{{ row.tool }}</td><td>{{ row.type }}</td><td>{{ row.strength }}</td><td>{{ row.scenario }}</td><td>{{ row.pricing }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="standalone-cta">
    <a href="index.html" class="cta-btn">返回首页</a>
    <a href="ai-learning-roadmap.html" class="cta-btn cta-btn-outline">查看学习路线</a>
  </div>
</main>
<footer>
  <p>{{ footer.text }} · <a href="{{ footer.github }}" target="_blank" rel="noopener">GitHub</a></p>
</footer>
<script src="analytics.js"></script>
<script src="app.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ tool.name }} 教程 2026 | Bio AI</title>
  <meta name="description" content="{{ tool.description }}">
  <link rel="canonical" href="{{ meta.base_url }}tools/{{ tool.id }}.html">
  <meta property="og:title" content="{{ tool.name }} 教程 2026 | Bio AI">
  <meta property="og:description" content="{{ tool.description }}">
  <meta property="og:image" content="{{ meta.og_image }}">
  <meta property="og:url" content="{{ meta.base_url }}tools/{{ tool.id }}.html">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../style.css">
  <script type="application/ld+json">{{ schema_json | safe }}</script>
</head>
<body>
{% with standalone=true, home_href='../index.html', nav_prefix='../' %}
{% include 'partials/nav.j2' %}
{% endwith %}
<main class="standalone-page">
  <nav class="breadcrumb"><a href="../index.html">首页</a> / {{ tool.name }} 教程</nav>
  <div class="tool-header">
    <div class="tool-icon {{ tool.id }}">{{ tool.icon }}</div>
    <div>
      <h1>{{ tool.name }} 教程 2026</h1>
      <p class="standalone-lead">{{ tool.description }}</p>
    </div>
  </div>

  <div class="grid-2">
    <div class="card">
      <h3><span class="dot"></span> 快速入门</h3>
      <ol class="steps">{% for step in tool.getting_started_steps %}<li>{{ step | safe }}</li>{% endfor %}</ol>
    </div>
    <div class="card">
      <h3><span class="dot"></span> 核心功能</h3>
      <ul class="features">{% for f in tool.features %}<li><strong>{{ f.title }}</strong> — {{ f.description }}</li>{% endfor %}</ul>
    </div>
  </div>

  {% if tool.shortcuts %}
  <h3 class="resources-title">{{ tool.shortcuts.title }}</h3>
  <table class="compare-table">
    <thead><tr><th>快捷键</th><th>功能</th></tr></thead>
    <tbody>{% for row in tool.shortcuts.rows %}<tr><td>{{ row.key | safe }}</td><td>{{ row.action }}</td></tr>{% endfor %}</tbody>
  </table>
  {% endif %}

  {% if tool.video_resources %}
  <h3 class="resources-title">视频教程</h3>
  <div class="resource-grid">
    {% for r in tool.video_resources %}
    <div class="resource-item"><a href="{{ r.href }}" target="_blank" rel="noopener"><div class="resource-type {{ r.type_class }}">{{ r.type }}</div><h4>{{ r.title }}</h4><div class="resource-meta">{{ r.meta }}</div></a></div>
    {% endfor %}
  </div>
  {% endif %}

  {% if tool.text_resources %}
  <h3 class="resources-title">文字资料</h3>
  <div class="resource-grid">
    {% for r in tool.text_resources %}
    <div class="resource-item"><a href="{{ r.href }}" target="_blank" rel="noopener"><div class="resource-type {{ r.type_class }}">{{ r.type }}</div><h4>{{ r.title }}</h4><div class="resource-meta">{{ r.meta }}</div></a></div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="standalone-cta">
    <a href="../index.html#{{ tool.section_id }}" class="cta-btn" data-track="tool-goto-spa-{{ tool.id }}">在站内交互式教程中查看 →</a>
    <a href="../ai-tools-ranking.html" class="cta-btn cta-btn-outline">查看工具排行</a>
  </div>
</main>
<footer>
  <p>{{ footer.text }} · <a href="{{ footer.github }}" target="_blank" rel="noopener">GitHub</a></p>
</footer>
<script src="../analytics.js"></script>
<script src="../app.js"></script>
</body>
</html>

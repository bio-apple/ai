<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ guide.title }}</title>
  <meta name="description" content="{{ guide.lead }}">
  <link rel="canonical" href="{{ meta.base_url }}guides/{{ guide.slug }}.html">
  <meta property="og:title" content="{{ guide.title }}">
  <meta property="og:description" content="{{ guide.lead }}">
  <meta property="og:image" content="{{ meta.og_image }}">
  <meta property="og:url" content="{{ meta.base_url }}guides/{{ guide.slug }}.html">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../style.css">
  {% include 'partials/theme_boot.j2' %}
  <script type="application/ld+json">{{ schema_json | safe }}</script>
</head>
<body>
{% include 'partials/ux_widgets.j2' %}
{% with standalone=true, home_href='../index.html', nav_prefix='../' %}
{% include 'partials/nav.j2' %}
{% endwith %}
<main class="standalone-page">
  <nav class="breadcrumb"><a href="../index.html">首页</a> / 学习指南 / {{ guide.h1 }}</nav>
  <div class="standalone-hero">
    <h1>{{ guide.h1 }}</h1>
    <p class="standalone-lead">{{ guide.lead }}</p>
  </div>
  <div class="card">
    <h3><span class="dot" style="background:{{ path.dot_color }}"></span> {{ path.title }}</h3>
    <ol class="steps">
      {% for step in path.steps %}<li>{{ step }}</li>{% endfor %}
    </ol>
  </div>
  <div class="standalone-cta">
    <a href="../index.html#section-cases" class="cta-btn">开始实战</a>
    <a href="../ai-learning-roadmap.html" class="cta-btn cta-btn-outline">完整学习路线</a>
  </div>
</main>
<footer>
  <p>{{ footer.text }} · <a href="{{ footer.github }}" target="_blank" rel="noopener">GitHub</a></p>
</footer>
<script src="../analytics.js"></script>
<script src="../ux.js"></script>
<script src="../app.js"></script>
</body>
</html>

<section id="section-cases" class="section cases-section">
  <main>
    <div class="tool-header">
      <div class="tool-icon" style="background:rgba(59,130,246,0.15);color:var(--accent)">⚡</div>
      <div>
        <h2>{{ cases.header.title }}</h2>
        <p class="desc">{{ cases.header.description }}</p>
      </div>
    </div>

    <div class="case-filters">
      {% for f in cases.tool_filters %}
      <button class="case-filter{% if f == 'all' %} active{% endif %}" data-filter="{{ f }}">{{ nav_labels.get(f, f) if f != 'all' else '全部' }}</button>
      {% endfor %}
    </div>

    <div class="case-scenario-filters">
      <span class="case-scenario-label">按场景：</span>
      {% for s in cases.scenario_filters %}
      <button class="case-scenario{% if s.id == 'all' %} active{% endif %}" data-scenario="{{ s.id }}">{{ s.label }}</button>
      {% endfor %}
    </div>

    {% for case in cases.cases %}
    <article class="case-card" id="case-{{ loop.index }}" data-tool="{{ case.tool }}" data-scenario="{{ case.scenarios | join(' ') }}">
      <div class="case-header" role="button" tabindex="0">
        <div class="case-meta">
          <span class="case-badge {{ case.tool }}">{{ tool_names.get(case.tool, case.tool) }}</span>
          <span class="case-level">{{ case.level }}</span>
          <span class="case-time">{{ case.duration }}</span>
          {% for tag in case.tags %}<span class="case-tag">{{ tag }}</span>{% endfor %}
        </div>
        <h3>{{ case.title }}</h3>
        <p class="case-summary">{{ case.summary }}</p>
        <span class="case-toggle">展开步骤</span>
      </div>
      <div class="case-body">
        {% if case.goal %}<div class="case-goal"><strong>目标：</strong>{{ case.goal }}</div>{% endif %}
        {% if case.prereq %}<div class="case-prereq"><strong>准备：</strong>{{ case.prereq }}</div>{% endif %}
        <ol class="case-steps">
          {% for step in case.steps %}
          <li>
            {% if step.title %}<div class="step-title">{{ step.title }}</div>{% endif %}
            {% for block in step.blocks %}
              {% if block.type == 'paragraph' %}<p>{{ block.content | safe }}</p>
              {% elif block.type == 'prompt' %}<div class="prompt-block">{{ block.content }}</div>
              {% elif block.type == 'tip' %}<p class="step-tip">{{ block.content | safe }}</p>
              {% elif block.type == 'checklist' %}
              <ul class="checklist">{% for item in block.content %}<li>{{ item }}</li>{% endfor %}</ul>
              {% endif %}
            {% endfor %}
          </li>
          {% endfor %}
        </ol>
      </div>
    </article>
    {% endfor %}

    {% if cases.general_tips %}
    <div class="case-tips-card">
      <h3>{{ cases.general_tips.title }}</h3>
      <div class="grid-2">
        {% for col in cases.general_tips.columns %}
        <ul class="features">
          {% for item in col %}<li>{{ item | safe }}</li>{% endfor %}
        </ul>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </main>
</section>

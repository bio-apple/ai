<section id="{{ tool.section_id }}" class="section {{ tool.id }}-section">
  <main>
    <div class="tool-header">
      <div class="tool-icon {{ tool.id }}">{{ tool.icon }}</div>
      <div>
        <h2>{{ tool.name }}</h2>
        <p class="desc">{{ tool.description }}</p>
        <p class="tool-page-link"><a href="tools/{{ tool.id }}.html" data-track="tool-standalone-{{ tool.id }}">查看独立教程页（SEO）→</a></p>
      </div>
    </div>
    <div class="grid-2">
      <div class="card">
        <h3><span class="dot"></span> 快速入门</h3>
        <ol class="steps">
          {% for step in tool.getting_started_steps %}<li>{{ step | safe }}</li>{% endfor %}
        </ol>
      </div>
      <div class="card">
        <h3><span class="dot"></span> 核心功能</h3>
        <ul class="features">
          {% for f in tool.features %}
          <li><strong>{{ f.title }}</strong> — {{ f.description }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>

    {% if tool.shortcuts %}
    <h3 class="resources-title">{{ tool.shortcuts.title }}</h3>
    <table class="compare-table">
      <thead><tr><th>快捷键</th><th>功能</th></tr></thead>
      <tbody>
        {% for row in tool.shortcuts.rows %}
        <tr><td>{{ row.key | safe }}</td><td>{{ row.action }}</td></tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}

    {% if tool.video_resources %}
    <h3 class="resources-title">📹 视频教程</h3>
    <div class="resource-grid">
      {% for r in tool.video_resources %}
      <div class="resource-item">
        <a href="{{ r.href }}" target="_blank" rel="noopener">
          <div class="resource-type {{ r.type_class }}">{{ r.type }}</div>
          <h4>{{ r.title }}</h4>
          <div class="resource-meta">{{ r.meta }}</div>
        </a>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if tool.text_resources %}
    <h3 class="resources-title">📄 文字资料</h3>
    <div class="resource-grid">
      {% for r in tool.text_resources %}
      <div class="resource-item">
        <a href="{{ r.href }}" target="_blank" rel="noopener">
          <div class="resource-type {{ r.type_class }}">{{ r.type }}</div>
          <h4>{{ r.title }}</h4>
          <div class="resource-meta">{{ r.meta }}</div>
        </a>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </main>
</section>

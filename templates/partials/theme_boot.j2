<script>
(function () {
  try {
    var key = 'bioai-theme';
    var stored = localStorage.getItem(key);
    var theme = stored === 'dark' || stored === 'light'
      ? stored
      : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    document.documentElement.dataset.theme = theme;
  } catch (e) {}
})();
</script>

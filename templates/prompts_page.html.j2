<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page.title }}</title>
  <meta name="description" content="{{ page.lead }}">
  <meta name="keywords" content="Prompt,提示词,ChatGPT,Claude,Cursor,AI模板">
  <link rel="canonical" href="{{ meta.base_url }}prompts/library.html">
  <meta property="og:title" content="{{ page.title }}">
  <meta property="og:description" content="{{ page.lead }}">
  <meta property="og:image" content="{{ meta.og_image }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../style.css">
  {% include 'partials/theme_boot.j2' %}
  <script type="application/ld+json">{{ schema_json | safe }}</script>
</head>
<body>
{% include 'partials/ux_widgets.j2' %}
{% with standalone=true, home_href='../index.html', nav_prefix='../' %}
{% include 'partials/nav.j2' %}
{% endwith %}
<main class="standalone-page">
  <nav class="breadcrumb"><a href="../index.html">首页</a> / Prompt 库</nav>
  <div class="standalone-hero">
    <h1>{{ page.h1 }}</h1>
    <p class="standalone-lead">{{ page.lead }}</p>
    <p class="library-meta" id="prompts-count-meta"></p>
  </div>
  <div class="library-toolbar" id="prompts-toolbar">
    <button type="button" class="library-filter active" data-prompt-cat="all">全部</button>
    {% for cat in prompts.categories %}
    <button type="button" class="library-filter" data-prompt-cat="{{ cat.id }}">{{ cat.icon }} {{ cat.label }}</button>
    {% endfor %}
  </div>
  <div id="prompts-list" class="prompts-grid">
    <p class="loading-hint">加载 Prompt 库…</p>
  </div>
  <div class="standalone-cta">
    <a href="../index.html#section-prompts" class="cta-btn">返回站内 Prompt 库</a>
    <a href="../index.html#section-cases" class="cta-btn cta-btn-outline">查看实战案例</a>
  </div>
</main>
<footer>
  <p>{{ footer.text }} · <a href="{{ footer.github }}" target="_blank" rel="noopener">GitHub</a></p>
</footer>
<script src="../analytics.js"></script>
<script src="../ux.js"></script>
<script src="../app.js"></script>
<script src="../prompts.js"></script>
</body>
</html>

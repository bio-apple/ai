{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-apple.github.io/ai/schemas/recommend-rules.schema.json",
  "title": "Recommend rules",
  "type": "object",
  "required": ["schema_version", "options", "fallback"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "updated_from": { "type": "string" },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "tools"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string" },
          "tools": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "keywords": { "type": "array", "items": { "type": "string" } },
          "guide": { "type": ["string", "null"] },
          "path_title": { "type": ["string", "null"] },
          "steps": { "type": "array", "items": { "type": "string" } },
          "examples": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "fallback": {
      "type": "object",
      "required": ["tools"],
      "properties": {
        "tools": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "guide": { "type": "string" },
        "path_title": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } }
      }
    },
    "relations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "alternatives": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "note"],
              "properties": {
                "id": { "type": "string" },
                "note": { "type": "string" }
              }
            }
          },
          "complements": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "note"],
              "properties": {
                "id": { "type": "string" },
                "note": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}

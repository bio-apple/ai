{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["batches"],
  "properties": {
    "updated_at": { "type": "string" },
    "seen_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "batches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date"],
        "properties": {
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "timezone": { "type": "string" },
          "criteria": { "type": "object" },
          "categories": {
            "type": "object",
            "required": ["recent_7d", "last_6m"],
            "properties": {
              "recent_7d": { "$ref": "#/$defs/videoCategory" },
              "last_6m": { "$ref": "#/$defs/videoCategory" }
            },
            "additionalProperties": false
          },
          "videos": {
            "type": "array",
            "items": { "$ref": "#/$defs/videoItem" },
            "description": "旧版批次结构，仅用于向后兼容"
          }
        },
        "oneOf": [
          { "required": ["categories"] },
          { "required": ["videos"] }
        ]
      }
    }
  },
  "$defs": {
    "videoCategory": {
      "type": "object",
      "required": ["label", "window", "min_count", "videos"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "window": {
          "type": "object",
          "minProperties": 1,
          "properties": {
            "hours": { "type": "number", "minimum": 1 },
            "days": { "type": "number", "minimum": 1 }
          }
        },
        "min_count": { "type": "number", "minimum": 0 },
        "videos": {
          "type": "array",
          "items": { "$ref": "#/$defs/videoItem" }
        }
      }
    },
    "videoItem": {
      "type": "object",
      "required": ["id", "title", "summary", "url", "thumbnail", "channel", "views", "max_height"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 8 },
        "url": { "type": "string", "pattern": "^https://www\\.youtube\\.com/watch\\?v=" },
        "thumbnail": { "type": "string" },
        "channel": { "type": "string" },
        "subscribers": { "type": "number" },
        "views": { "type": "number" },
        "duration": { "type": "string" },
        "max_height": { "type": "number", "minimum": 720 },
        "score": { "type": "number" },
        "published_at": { "type": "string" }
      }
    }
  }
}

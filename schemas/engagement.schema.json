{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-apple.github.io/ai/schemas/engagement.schema.json",
  "type": "object",
  "required": ["schema_version", "updated_at", "page_views", "favorites_count", "tools"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "updated_at": { "type": "string", "minLength": 8 },
    "label": { "type": "string" },
    "page_views": { "type": "integer", "minimum": 0 },
    "favorites_count": { "type": "integer", "minimum": 0 },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "today_clicks"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "icon": { "type": "string" },
          "today_clicks": { "type": "integer", "minimum": 0 },
          "updated_at": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}

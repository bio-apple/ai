{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-apple.github.io/ai/schemas/oss-projects.schema.json",
  "title": "OSS projects by domain",
  "type": "object",
  "required": ["domains"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "updated_at": { "type": "string" },
    "title": { "type": "string" },
    "lead": { "type": "string" },
    "rules": {
      "type": "object",
      "properties": {
        "min_stars": { "type": "integer", "minimum": 1 },
        "top_n_per_app": { "type": "integer", "minimum": 1, "maximum": 5 },
        "refresh": { "type": "string" }
      }
    },
    "domains": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["id", "label", "projects"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "apps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "label"],
              "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" },
                "blurb": { "type": "string" }
              }
            }
          },
          "projects": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "type": "object",
              "required": ["id", "repo", "name", "url", "stars"],
              "properties": {
                "id": { "type": "string" },
                "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
                "name": { "type": "string" },
                "description": { "type": "string" },
                "stars": { "type": "integer", "minimum": 50000 },
                "url": { "type": "string" },
                "language": { "type": "string" },
                "app": { "type": "string" },
                "role": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
